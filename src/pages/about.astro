---
import NordicLayout from '../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const navBase = `${base}${lang === 'es' ? 'es/' : ''}`;
---

<NordicLayout title={t.about.title} pageLang={lang}>
  <!-- Hero Section - Nordic pattern -->
  <section class="nordic-hero">
    <div class="nordic-hero-left">
      <span class="nordic-kicker">{lang === 'fr' ? 'La fondatrice' : 'La fundadora'}</span>
      <h1 class="nordic-headline">{t.about.sonia.title}</h1>
      <p class="nordic-subtitle">{t.about.sonia.nationality}</p>
      <p class="nordic-approach">{t.about.sonia.approach}</p>
      <a href="#bio" class="nordic-btn">
        {lang === 'fr' ? 'Découvrir son parcours' : 'Descubrir su trayectoria'}
        <svg width="1rem" height="1rem" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="nordic-hero-right">
      <div class="hero-blob-green"></div>
      <div class="hero-blob-violet"></div>
    </div>
  </section>

  <!-- Bio Section -->
  <section id="bio" class="nordic-section">
    <div class="nordic-section-inner">
      <div class="nordic-profile-card animate-on-scroll">
        <div class="nordic-profile-header">
          <div class="nordic-profile-photo">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
          </div>
          <div>
            <h2 class="nordic-profile-name">{t.about.sonia.title}</h2>
            <p class="nordic-profile-nationality">{t.about.sonia.nationality}</p>
          </div>
        </div>
        <div class="nordic-profile-bio">
          {t.about.sonia.bio.map((paragraph: string) => (
            <p class="nordic-profile-bio-para">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Education & Experience - Two Column -->
  <section class="nordic-section nordic-section-alt">
    <div class="nordic-section-inner">
      <div class="nordic-cv-grid">
        <!-- Education Column -->
        <div class="nordic-cv-column animate-on-scroll">
          <div class="nordic-cv-header education">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
            <h3>{t.about.sonia.education.title}</h3>
          </div>
          <div class="nordic-cv-items">
            {t.about.sonia.education.items.map((item: string, index: number) => (
              <div class="nordic-cv-item" style={`transition-delay: ${index * 0.05}s`}>
                <div class="nordic-cv-icon education">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Experience Column -->
        <div class="nordic-cv-column animate-on-scroll" style="transition-delay: 0.1s">
          <div class="nordic-cv-header experience">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
            <h3>{t.about.sonia.experience.title}</h3>
          </div>
          <div class="nordic-cv-items">
            {t.about.sonia.experience.items.map((item: string, index: number) => (
              <div class="nordic-cv-item" style={`transition-delay: ${index * 0.05}s`}>
                <div class="nordic-cv-icon experience">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14"/>
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Role at Espace Bienestar -->
  <section class="nordic-section">
    <div class="nordic-section-inner">
      <div class="nordic-current-role animate-on-scroll">
        <div class="nordic-role-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            <path d="M3.3 7l8.7 5 8.7-5M12 22V12"/>
          </svg>
          <h3>{t.about.sonia.currentRole.title}</h3>
        </div>
        <p class="nordic-role-description">{t.about.sonia.currentRole.description}</p>
        <div class="nordic-role-activities">
          {t.about.sonia.currentRole.activities.map((activity: { name: string; for: string; focus: string }, index: number) => (
            <div class="nordic-role-activity" style={`transition-delay: ${index * 0.1}s`}>
              <h4>{activity.name}</h4>
              <p class="nordic-role-for">{activity.for}</p>
              <p class="nordic-role-focus">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 5l7 7-7 7"/>
                </svg>
                {activity.focus}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="nordic-cta-section">
    <div class="nordic-cta-inner animate-on-scroll">
      <h2 class="nordic-cta-title">
        {lang === 'fr' ? 'Découvrez nos ateliers' : 'Descubra nuestros talleres'}
      </h2>
      <p class="nordic-cta-text">
        {lang === 'fr'
          ? 'Explorez les activités que je propose pour votre bien-être.'
          : 'Explore las actividades que propongo para su bienestar.'}
      </p>
      <div class="nordic-cta-buttons">
        <a href={`${navBase}activities/gymnastics`} class="nordic-cta-btn gymnastics">
          {lang === 'fr' ? 'Gymnastiques' : 'Gimnasias'}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={`${navBase}activities/theatre`} class="nordic-cta-btn theatre">
          {lang === 'fr' ? 'Théâtre' : 'Teatro'}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</NordicLayout>

<style>
  .nordic-approach {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--nordic-text);
    opacity: 0.8;
    line-height: 1.8;
    max-width: 420px;
    margin-bottom: 2rem;
  }

  .hero-blob-green {
    position: absolute;
    right: 10%;
    top: 20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(135, 179, 122, 0.25), transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  .hero-blob-violet {
    position: absolute;
    right: 25%;
    bottom: 20%;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(201, 166, 198, 0.3), transparent 70%);
    border-radius: 50%;
    filter: blur(50px);
    pointer-events: none;
  }

  .nordic-profile-card {
    background: var(--nordic-white);
    border-radius: 1.5rem;
    padding: 3rem;
    box-shadow: 0 4px 24px rgba(44, 62, 80, 0.06);
    border-top: 4px solid var(--nordic-primary);
  }

  .nordic-profile-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--nordic-ice);
  }

  .nordic-profile-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--nordic-ice);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nordic-primary);
    flex-shrink: 0;
  }

  .nordic-profile-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--nordic-shadow);
    margin-bottom: 0.25rem;
  }

  .nordic-profile-nationality {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--nordic-text);
    opacity: 0.6;
  }

  .nordic-profile-bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nordic-profile-bio-para {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--nordic-text);
  }

  .nordic-cv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .nordic-cv-column {
    background: var(--nordic-white);
    border-radius: 1.25rem;
    padding: 2rem;
  }

  .nordic-cv-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--nordic-ice);
  }

  .nordic-cv-header h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--nordic-shadow);
  }

  .nordic-cv-header.education {
    color: var(--nordic-primary);
  }

  .nordic-cv-header.experience {
    color: var(--nordic-violet);
  }

  .nordic-cv-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nordic-cv-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--nordic-text);
    line-height: 1.5;
  }

  .nordic-cv-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nordic-cv-icon.education {
    background: var(--nordic-ice);
    color: var(--nordic-primary);
  }

  .nordic-cv-icon.experience {
    background: var(--nordic-frost);
    color: var(--nordic-violet);
  }

  .nordic-current-role {
    background: linear-gradient(135deg, var(--nordic-ice) 0%, var(--nordic-frost) 100%);
    border-radius: 1.5rem;
    padding: 2.5rem;
    border: 1px solid rgba(135, 179, 122, 0.2);
  }

  .nordic-role-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    color: var(--nordic-primary);
  }

  .nordic-role-header h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--nordic-shadow);
  }

  .nordic-role-description {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--nordic-text);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .nordic-role-activities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .nordic-role-activity {
    background: var(--nordic-white);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(44, 62, 80, 0.04);
  }

  .nordic-role-activity h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--nordic-shadow);
    margin-bottom: 0.5rem;
  }

  .nordic-role-for {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--nordic-text);
    opacity: 0.7;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .nordic-role-focus {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--nordic-primary);
  }

  .nordic-role-focus svg {
    width: 14px;
    transition: transform 0.2s;
  }

  .nordic-cta-section {
    padding: 5rem 4rem;
    background: var(--nordic-mist);
    text-align: center;
  }

  .nordic-cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .nordic-cta-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    color: var(--nordic-shadow);
    margin-bottom: 1rem;
  }

  .nordic-cta-text {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    color: var(--nordic-text);
    opacity: 0.7;
    margin-bottom: 2rem;
  }

  .nordic-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .nordic-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .nordic-cta-btn.gymnastics {
    background: var(--nordic-primary);
    color: var(--nordic-white);
  }

  .nordic-cta-btn.gymnastics:hover {
    background: var(--nordic-shadow);
    transform: translateY(-2px);
  }

  .nordic-cta-btn.theatre {
    background: var(--nordic-violet);
    color: var(--nordic-white);
  }

  .nordic-cta-btn.theatre:hover {
    background: var(--nordic-shadow);
    transform: translateY(-2px);
  }

  .nordic-cta-btn svg {
    width: 16px;
    transition: transform 0.2s;
  }

  .nordic-cta-btn:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .nordic-section {
      padding: 3rem 1.5rem;
    }

    .nordic-cv-grid {
      grid-template-columns: 1fr;
    }

    .nordic-role-activities {
      grid-template-columns: 1fr;
    }

    .nordic-cta-section {
      padding: 3rem 1.5rem;
    }

    .nordic-profile-card {
      padding: 2rem;
    }

    .nordic-profile-header {
      flex-direction: column;
      text-align: center;
    }

    .nordic-cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .nordic-cta-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>