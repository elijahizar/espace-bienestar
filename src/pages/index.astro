---
import NordicLayout from '../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: 'Mouvement conscient',
    link: `${base}activities/gymnastics`,
    cta: 'Découvrir'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: 'Expression créative',
    link: `${base}activities/theatre`,
    cta: 'Découvrir'
  }
];
---

<NordicLayout title="Espace Bienestar – Accueil" pageLang={lang}>
  <section class="nordic-hero">
    <div class="nordic-hero-left">
      <span class="nordic-kicker">Espace Bienestar · Billère 64140 · France</span>
      <h2 class="nordic-headline">
        L'Art et Le Corps.
      </h2>
      <p class="nordic-subtitle">{t.home.introText}</p>
      <ul class="nordic-hero-ateliers">
        {t.home.ateliers.map((atelier) => (
          <li>
            <span class="nordic-hero-dot" aria-hidden="true"></span>
            {atelier}
          </li>
        ))}
      </ul>
      <a href={`${base}about`} class="nordic-intro-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        Coordinatrice SONIA CUTRI
      </a>
    </div>
    <div class="nordic-hero-right">
         <img src={`${base}img/siluetas.webp`} alt="Espace Bienestar hero" />
    </div>
  </section>

  <section class="nordic-activities">
    <a href={activities[0].link} class="nordic-activity gymnastics">
      <span class="nordic-activity-label">{activities[0].subtitle}</span>
      <h2 class="nordic-activity-title">{activities[0].title}</h2>
      <p class="nordic-activity-desc">Gymnastique Posturale Consciente<br>
Gymnastique Rythmique Expressive</p>
      <span class="nordic-activity-cta">
        {activities[0].cta}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="nordic-activity theatre">
      <span class="nordic-activity-label">{activities[1].subtitle}</span>
      <h2 class="nordic-activity-title">{activities[1].title}</h2>
      <p class="nordic-activity-desc">Atelier de Théâtre et Bien-Etre<br>
Atelier de Théâtre Amateur
</p>
      <span class="nordic-activity-cta">
        {activities[1].cta}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>
</NordicLayout>
