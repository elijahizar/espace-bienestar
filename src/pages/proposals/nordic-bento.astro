---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');

const base = import.meta.env.BASE_URL;
---

<ProposalLayout title="Proposition - Nordique (Bento Grid)" styleName="05 · Nordique — Bento Grid">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

:root {
--nordic-ice: #E0F2F1;
--nordic-soft-blue: #A7C7E7;
--nordic-deep: #4A6572;
--nordic-white: #FFFFFF;
--nordic-frost: #D4E8F0;
--nordic-shadow: #2C3E50;
--nordic-mist: #E8F0F5;
--nordic-card-radius: 16px;
--nordic-card-shadow: 0 4px 24px rgba(44, 62, 80, 0.06);
--nordic-card-shadow-hover: 0 8px 32px rgba(44, 62, 80, 0.12);
--nordic-grid-gap: 1.25rem;
}

html { scroll-behavior: smooth; }

.bento-page {
min-height: 100vh;
background: #F0F4F5;
color: var(--nordic-deep);
}

.bento-header {
display: flex;
justify-content: space-between;
align-items: center;
padding: 1.25rem 4rem;
background: var(--nordic-white);
border-bottom: 1px solid var(--nordic-ice);
}

.bento-logo {
font-family: 'Inter', sans-serif;
font-size: 1.1rem;
font-weight: 600;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--nordic-deep);
}

.bento-nav {
display: flex;
gap: 3rem;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.8rem;
font-weight: 400;
}

.bento-nav a {
color: var(--nordic-deep);
text-decoration: none;
opacity: 0.6;
transition: opacity 0.2s;
}

.bento-nav a:hover { opacity: 1; }

/* ── Bento grid container ── */
.bento-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
grid-auto-rows: minmax(140px, auto);
gap: var(--nordic-grid-gap);
max-width: 1120px;
margin: 0 auto;
padding: 2rem 2rem 3rem;
}

/* ── Hero card ── */
.bento-hero {
grid-column: 1 / -1;
grid-row: span 2;
border-radius: var(--nordic-card-radius);
box-shadow: var(--nordic-card-shadow);
overflow: hidden;
display: grid;
grid-template-columns: 1.2fr 1fr;
background: var(--nordic-white);
cursor: pointer;
transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
text-decoration: none;
color: inherit;
}

.bento-hero:hover {
transform: translateY(-2px);
box-shadow: var(--nordic-card-shadow-hover);
}

.bento-hero-text {
padding: 3.5rem 4rem;
display: flex;
flex-direction: column;
justify-content: center;
}

.bento-hero-kicker {
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.7rem;
font-weight: 500;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(--nordic-soft-blue);
margin-bottom: 1.5rem;
}

.bento-hero-headline {
font-family: 'Inter', sans-serif;
font-size: clamp(2.5rem, 5vw, 4rem);
font-weight: 300;
line-height: 1.2;
color: var(--nordic-shadow);
margin-bottom: 1.25rem;
}

.bento-hero-headline em {
font-style: italic;
font-weight: 300;
color: var(--nordic-soft-blue);
}

.bento-hero-subtitle {
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.95rem;
font-weight: 300;
color: var(--nordic-deep);
opacity: 0.7;
max-width: 380px;
line-height: 1.8;
margin-bottom: 2rem;
}

.bento-hero-cta {
display: inline-flex;
align-items: center;
gap: 0.75rem;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.8rem;
font-weight: 500;
letter-spacing: 0.05em;
background: var(--nordic-deep);
color: var(--nordic-white);
text-decoration: none;
padding: 0.85rem 2rem;
border-radius: 999px;
transition: background 0.3s;
width: fit-content;
}

.bento-hero-cta:hover { background: var(--nordic-shadow); }
.bento-hero-cta svg { width: 1rem; }

.bento-hero-art {
background: linear-gradient(135deg, var(--nordic-ice) 0%, var(--nordic-soft-blue) 100%);
position: relative;
display: flex;
align-items: center;
justify-content: center;
overflow: hidden;
}

.bento-hero-art::before {
content: '';
position: absolute;
inset: 0;
background:
radial-gradient(circle at 30% 40%, rgba(255,255,255,0.3) 0%, transparent 40%),
radial-gradient(circle at 70% 60%, rgba(74,101,114,0.1) 0%, transparent 35%);
}

.bento-crystal {
position: relative;
width: 140px;
height: 180px;
}

.bento-crystal-shape {
position: absolute;
border: 1px solid rgba(255,255,255,0.5);
background: rgba(255,255,255,0.1);
}

.bento-crystal-shape:nth-child(1) { width: 70px; height: 100px; top: 40px; left: 35px; transform: rotate(15deg); }
.bento-crystal-shape:nth-child(2) { width: 55px; height: 80px; top: 15px; left: 60px; transform: rotate(-10deg); border-color: rgba(255,255,255,0.3); }
.bento-crystal-shape:nth-child(3) { width: 45px; height: 70px; top: 70px; left: 15px; transform: rotate(25deg); border-color: rgba(255,255,255,0.4); background: rgba(167,199,231,0.1); }

.bento-ring {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
border-radius: 50%;
border: 1px solid rgba(255,255,255,0.15);
}

.bento-ring:nth-child(4) { width: 120px; height: 120px; }
.bento-ring:nth-child(5) { width: 170px; height: 170px; border-color: rgba(255,255,255,0.08); }
.bento-ring:nth-child(6) { width: 220px; height: 220px; border-color: rgba(255,255,255,0.05); }

/* ── Activity cards ── */
.bento-activity {
border-radius: var(--nordic-card-radius);
box-shadow: var(--nordic-card-shadow);
padding: 3rem;
display: flex;
flex-direction: column;
justify-content: flex-end;
text-decoration: none;
overflow: hidden;
position: relative;
cursor: pointer;
transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
}

.bento-activity:hover {
transform: translateY(-2px);
box-shadow: var(--nordic-card-shadow-hover);
}

.bento-activity::before {
content: '';
position: absolute;
inset: 0;
transition: transform 0.5s ease;
}

.bento-activity:hover::before { transform: scale(1.02); }

.bento-gym {
grid-column: 1 / 3;
grid-row: span 2;
background: linear-gradient(180deg, var(--nordic-ice) 0%, var(--nordic-soft-blue) 100%);
color: var(--nordic-shadow);
}

.bento-gym::before {
background: radial-gradient(circle at 60% 25%, rgba(255,255,255,0.35) 0%, transparent 50%);
}

.bento-theatre {
grid-column: 3 / 5;
grid-row: span 2;
background: linear-gradient(180deg, var(--nordic-deep) 0%, var(--nordic-shadow) 100%);
color: var(--nordic-white);
}

.bento-theatre::before {
background: radial-gradient(circle at 40% 70%, rgba(167,199,231,0.15) 0%, transparent 40%);
}

.bento-activity-label {
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.65rem;
font-weight: 500;
letter-spacing: 0.2em;
text-transform: uppercase;
margin-bottom: 0.75rem;
position: relative;
z-index: 1;
}

.bento-gym .bento-activity-label { color: var(--nordic-deep); opacity: 0.6; }
.bento-theatre .bento-activity-label { color: var(--nordic-frost); }

.bento-activity-title {
font-family: 'Inter', sans-serif;
font-size: 1.75rem;
font-weight: 300;
line-height: 1.3;
margin-bottom: 0.75rem;
position: relative;
z-index: 1;
}

.bento-activity-desc {
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.82rem;
font-weight: 300;
line-height: 1.7;
margin-bottom: 1.5rem;
max-width: 280px;
position: relative;
z-index: 1;
}

.bento-gym .bento-activity-desc { color: var(--nordic-deep); }
.bento-theatre .bento-activity-desc { color: rgba(255,255,255,0.6); }

.bento-activity-cta {
display: inline-flex;
align-items: center;
gap: 0.6rem;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.75rem;
font-weight: 500;
letter-spacing: 0.05em;
position: relative;
z-index: 1;
}

.bento-gym .bento-activity-cta { color: var(--nordic-deep); }
.bento-theatre .bento-activity-cta { color: var(--nordic-soft-blue); }

.bento-activity-cta svg {
width: 1.1rem;
transition: transform 0.3s;
}

.bento-activity:hover .bento-activity-cta svg {
transform: translateX(5px);
}

/* ── Quote card ── */
.bento-quote {
grid-column: 1 / 3;
border-radius: var(--nordic-card-radius);
box-shadow: var(--nordic-card-shadow);
background: var(--nordic-white);
padding: 2.5rem 3rem;
display: flex;
flex-direction: column;
justify-content: center;
position: relative;
overflow: hidden;
}

.bento-quote::before {
content: '\201C';
position: absolute;
top: -0.1rem;
left: 1.5rem;
font-family: 'Inter', sans-serif;
font-size: 6rem;
font-weight: 300;
color: var(--nordic-soft-blue);
opacity: 0.12;
line-height: 1;
pointer-events: none;
}

.bento-quote-text {
font-family: 'Inter', sans-serif;
font-size: 1.2rem;
font-weight: 300;
font-style: italic;
color: var(--nordic-shadow);
line-height: 1.8;
position: relative;
z-index: 1;
}

/* ── Sonia card ── */
.bento-sonia {
grid-column: 3 / 5;
border-radius: var(--nordic-card-radius);
box-shadow: var(--nordic-card-shadow);
background: var(--nordic-white);
padding: 2.5rem 3rem;
display: flex;
flex-direction: column;
justify-content: center;
border-left: 3px solid var(--nordic-soft-blue);
}

.bento-sonia-name {
font-family: 'Inter', sans-serif;
font-size: 1.35rem;
font-weight: 500;
color: var(--nordic-shadow);
margin-bottom: 0.3rem;
}

.bento-sonia-role {
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.75rem;
font-weight: 400;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(--nordic-soft-blue);
margin-bottom: 1.5rem;
}

.bento-sonia-links {
display: flex;
flex-direction: column;
gap: 0.75rem;
}

.bento-sonia-link {
display: inline-flex;
align-items: center;
gap: 0.6rem;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.82rem;
font-weight: 400;
color: var(--nordic-deep);
text-decoration: none;
padding: 0.5rem 0;
border-bottom: 1px solid var(--nordic-ice);
transition: color 0.2s, padding-left 0.2s;
}

.bento-sonia-link:hover {
color: var(--nordic-soft-blue);
padding-left: 0.5rem;
}

.bento-sonia-link svg { width: 1rem; }

/* ── CTA banner ── */
.bento-cta {
grid-column: 1 / -1;
border-radius: var(--nordic-card-radius);
background: linear-gradient(135deg, var(--nordic-deep) 0%, var(--nordic-shadow) 100%);
padding: 3rem;
display: flex;
flex-direction: column;
align-items: center;
text-align: center;
}

.bento-cta-heading {
font-family: 'Inter', sans-serif;
font-size: 1.5rem;
font-weight: 300;
color: var(--nordic-white);
margin-bottom: 1.5rem;
}

.bento-cta-btn {
display: inline-flex;
align-items: center;
gap: 0.75rem;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.85rem;
font-weight: 500;
letter-spacing: 0.05em;
background: var(--nordic-white);
color: var(--nordic-shadow);
text-decoration: none;
padding: 1rem 2.5rem;
border-radius: 999px;
transition: all 0.3s;
}

.bento-cta-btn:hover {
background: var(--nordic-ice);
}

.bento-cta-btn svg { width: 1rem; }

/* ── Footer ── */
.bento-footer {
padding: 1.5rem 2rem;
display: flex;
justify-content: center;
font-family: 'IBM Plex Sans', sans-serif;
font-size: 0.72rem;
color: var(--nordic-deep);
opacity: 0.4;
letter-spacing: 0.05em;
}

/* ── Responsive ── */
@media (max-width: 900px) {
.bento-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
.bento-nav { gap: 1.5rem; }
.bento-grid {
grid-template-columns: repeat(2, 1fr);
padding: 1.5rem 1.5rem 2.5rem;
}
.bento-hero { grid-column: 1 / -1; grid-template-columns: 1fr; }
.bento-hero-art { min-height: 200px; }
.bento-gym { grid-column: 1 / -1; }
.bento-theatre { grid-column: 1 / -1; }
.bento-quote { grid-column: 1 / -1; }
.bento-sonia { grid-column: 1 / -1; border-left: none; border-top: 3px solid var(--nordic-soft-blue); }
.bento-cta { grid-column: 1 / -1; }
}

@media (max-width: 600px) {
.bento-grid {
grid-template-columns: 1fr;
padding: 1rem 1rem 2rem;
gap: 1rem;
}
.bento-hero { grid-column: 1; }
.bento-hero-art { display: none; }
.bento-hero-text { padding: 2.5rem 2rem; }
.bento-gym { grid-column: 1; padding: 2rem 1.5rem; }
.bento-theatre { grid-column: 1; padding: 2rem 1.5rem; }
.bento-quote { grid-column: 1; padding: 2rem 1.5rem; }
.bento-sonia { grid-column: 1; padding: 2rem 1.5rem; }
.bento-cta { grid-column: 1; padding: 2rem 1.5rem; }
.bento-cta-heading { font-size: 1.2rem; }
.bento-footer { padding: 1rem; }
}
</style>

<div class="bento-page">
<header class="bento-header">
<div class="bento-logo">Espace Bienestar</div>
<nav class="bento-nav">
<a href={base}>Accueil</a>
    <a href={`${base}activities`}>Activités</a>
    <a href={`${base}about`}>À propos</a>
    <a href={`${base}contact`}>Contact</a>
</nav>
</header>

<div class="bento-grid">

<a href={`${base}contact`} class="bento-hero">
<div class="bento-hero-text">
<span class="bento-hero-kicker">Calme nordique · Billère · France</span>
<h1 class="bento-hero-headline">
Sérénité<br /><em>scandinave</em>
</h1>
<p class="bento-hero-subtitle">{t.home.intro}</p>
<span class="bento-hero-cta">
Commencer
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</span>
</div>
<div class="bento-hero-art">
<div class="bento-crystal">
<div class="bento-crystal-shape"></div>
<div class="bento-crystal-shape"></div>
<div class="bento-crystal-shape"></div>
<div class="bento-ring"></div>
<div class="bento-ring"></div>
<div class="bento-ring"></div>
</div>
</div>
</a>

<a href={`${base}activities/gymnastics`} class="bento-activity bento-gym">
<span class="bento-activity-label">Mouvement conscient</span>
<h2 class="bento-activity-title">{t.activities.gymnastics.title}</h2>
<p class="bento-activity-desc">Le mouvement conscient comme la glace qui coule avec grâce, chaque geste une méditation.</p>
<span class="bento-activity-cta">
Découvrir
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</span>
</a>

<a href={`${base}activities/theatre`} class="bento-activity bento-theatre">
<span class="bento-activity-label">Expression créative</span>
<h2 class="bento-activity-title">{t.activities.theatre.title}</h2>
<p class="bento-activity-desc">L'expression créative comme une aurore dans la nuit polaire, la voix qui s'éveille.</p>
<span class="bento-activity-cta">
Découvrir
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</span>
</a>

<div class="bento-quote">
<p class="bento-quote-text">{t.home.hero.subtitle} — Le calme du nord comme chemin vers le bien-être.</p>
</div>

<div class="bento-sonia">
<div class="bento-sonia-name">Sonia Cutri</div>
<div class="bento-sonia-role">Fondatrice</div>
<div class="bento-sonia-links">
<a href={`${base}about`} class="bento-sonia-link">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
Rencontrer Sonia
</a>
<a href={`${base}schedule`} class="bento-sonia-link">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
Voir les horaires
</a>
</div>
</div>

<div class="bento-cta">
<h3 class="bento-cta-heading">Prêt à commencer votre voyage ?</h3>
<a href={`${base}contact`} class="bento-cta-btn">
Réserver un cours
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</a>
</div>

</div>

<footer class="bento-footer">
© 2026 Espace Bienestar — Billère, France
</footer>
</div>
</ProposalLayout>
