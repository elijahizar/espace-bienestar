---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');

const base = import.meta.env.BASE_URL;

const activities = [
  { key: 'gymnastics', title: t.activities.gymnastics.title, subtitle: 'Mouvement conscient', link: `${base}activities/gymnastics`, cta: 'Découvrir' },
  { key: 'theatre', title: t.activities.theatre.title, subtitle: 'Expression créative', link: `${base}activities/theatre`, cta: 'Découvrir' }
];
---

<ProposalLayout title="Proposition - Wabi-Sabi" styleName="02 · Wabi-Sabi">
<style>
@import url('https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;700&family=Shippori+Mincho:wght@400;500&display=swap');

:root {
  --wabi-clay: #C4A484;
  --wabi-cream: #F5F0E8;
  --wabi-sand: #E8E0D5;
  --wabi-sage: #8B9A7D;
  --wabi-charcoal: #3D3D3D;
  --wabi-terracotta: #B86B4C;
  --wabi-ink: #2A2A28;
}

html { scroll-behavior: smooth; }

.font-display { font-family: 'Zen Old Mincho', serif; }
.font-body { font-family: 'Shippori Mincho', serif; }

.wabi-page {
  min-height: 100vh;
  background: var(--wabi-cream);
  color: var(--wabi-ink);
}

.wabi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 4rem;
  border-bottom: 1px solid rgba(61, 61, 61, 0.1);
}

.wabi-logo {
  font-family: 'Zen Old Mincho', serif;
  font-size: 1.25rem;
  letter-spacing: 0.3em;
  color: var(--wabi-charcoal);
}

.wabi-nav {
  display: flex;
  gap: 3rem;
  font-family: 'Shippori Mincho', serif;
  font-size: 0.8rem;
  color: var(--wabi-charcoal);
}

.wabi-nav a {
  color: var(--wabi-charcoal);
  text-decoration: none;
  transition: color 0.2s;
}

.wabi-nav a:hover { color: var(--wabi-terracotta); }

.wabi-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 85vh;
}

.wabi-hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 4rem 6rem;
  position: relative;
}

.wabi-hero-left::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, var(--wabi-sand) 0%, transparent 70%);
  border-radius: 50%;
  opacity: 0.5;
}

.wabi-kicker {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.7rem;
  letter-spacing: 0.4em;
  color: var(--wabi-terracotta);
  margin-bottom: 2rem;
  position: relative;
}

.wabi-headline {
  font-family: 'Zen Old Mincho', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 400;
  line-height: 1.3;
  color: var(--wabi-charcoal);
  margin-bottom: 2.5rem;
  position: relative;
}

.wabi-subtitle {
  font-family: 'Shippori Mincho', serif;
  font-size: 1rem;
  color: var(--wabi-sage);
  line-height: 1.9;
  max-width: 340px;
  margin-bottom: 3rem;
  position: relative;
}

.wabi-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Shippori Mincho', serif;
  font-size: 0.8rem;
  letter-spacing: 0.2em;
  color: var(--wabi-charcoal);
  text-decoration: none;
  padding: 1rem 0;
  border-bottom: 1px solid var(--wabi-charcoal);
  transition: all 0.3s;
  width: fit-content;
  position: relative;
}

.wabi-btn:hover {
  color: var(--wabi-terracotta);
  border-color: var(--wabi-terracotta);
}

.wabi-btn svg {
  width: 1rem;
  transition: transform 0.3s;
}

.wabi-btn:hover svg { transform: translateX(4px); }

.wabi-hero-right {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--wabi-sand) 0%, var(--wabi-cream) 100%);
}

.wabi-circle-art {
  width: 350px;
  height: 350px;
  position: relative;
}

.wabi-circle-art::before {
  content: '';
  position: absolute;
  inset: 0;
  border: 1px solid var(--wabi-clay);
  border-radius: 50%;
  opacity: 0.3;
}

.wabi-circle-art::after {
  content: '';
  position: absolute;
  inset: 30px;
  border: 1px solid var(--wabi-sage);
  border-radius: 50%;
  opacity: 0.4;
}

.wabi-symbol {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wabi-symbol svg {
  width: 100%;
  height: 100%;
}

.wabi-activity-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.wabi-activity {
  position: relative;
  padding: 5rem 4rem;
  min-height: 55vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  overflow: hidden;
}

.wabi-activity::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: transform 0.6s ease;
}

.wabi-activity:hover::before { transform: scale(1.02); }

.wabi-activity.gymnastics {
  background: linear-gradient(160deg, #D5DCC4 0%, #E8E5D8 100%);
}

.wabi-activity.gymnastics::before {
  background:
    radial-gradient(circle at 80% 20%, rgba(139, 154, 125, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(196, 164, 132, 0.1) 0%, transparent 40%);
}

.wabi-activity.theatre {
  background: linear-gradient(160deg, #E0D5C8 0%, #DDD0C3 100%);
}

.wabi-activity.theatre::before {
  background:
    radial-gradient(circle at 20% 20%, rgba(184, 107, 76, 0.12) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(139, 154, 125, 0.1) 0%, transparent 40%);
}

.wabi-activity-label {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--wabi-sage);
  margin-bottom: 1rem;
}

.wabi-activity-title {
  font-family: 'Zen Old Mincho', serif;
  font-size: 2rem;
  font-weight: 500;
  color: var(--wabi-charcoal);
  margin-bottom: 1rem;
}

.wabi-activity-desc {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.85rem;
  color: var(--wabi-sage);
  line-height: 1.8;
  max-width: 300px;
  margin-bottom: 2rem;
}

.wabi-activity-cta {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.75rem;
  letter-spacing: 0.2em;
  color: var(--wabi-terracotta);
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.wabi-activity-cta svg {
  width: 1.25rem;
  transition: transform 0.3s;
}

.wabi-activity:hover .wabi-activity-cta svg { transform: translateX(6px); }

.wabi-intro {
  padding: 6rem 4rem;
  text-align: center;
  background: var(--wabi-cream);
}

.wabi-intro-text {
  font-family: 'Zen Old Mincho', serif;
  font-size: 1.35rem;
  font-weight: 400;
  color: var(--wabi-charcoal);
  max-width: 550px;
  margin: 0 auto 3rem;
  line-height: 2;
}

.wabi-intro-link {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.75rem;
  letter-spacing: 0.25em;
  color: var(--wabi-terracotta);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: gap 0.3s;
}

.wabi-intro-link:hover { gap: 1rem; }

.wabi-footer {
  padding: 2rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(61, 61, 61, 0.1);
  font-family: 'Shippori Mincho', serif;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  color: var(--wabi-sage);
}

@media (max-width: 900px) {
  .wabi-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
  .wabi-nav { gap: 1.5rem; }
  .wabi-hero { grid-template-columns: 1fr; }
  .wabi-hero-left { padding: 3rem 1.5rem; order: 2; }
  .wabi-hero-right { min-height: 40vh; order: 1; }
  .wabi-circle-art { width: 250px; height: 250px; }
  .wabi-activity-section { grid-template-columns: 1fr; }
  .wabi-activity { padding: 3rem 1.5rem; }
  .wabi-intro { padding: 4rem 1.5rem; }
  .wabi-footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>

<div class="wabi-page">
  <header class="wabi-header">
    <div class="wabi-logo">Espace Bienestar</div>
    <nav class="wabi-nav">
<a href={base}>Accueil</a>
    <a href={`${base}activities`}>Activités</a>
    <a href={`${base}about`}>À propos</a>
    <a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <section class="wabi-hero">
    <div class="wabi-hero-left">
      <span class="wabi-kicker">BILLÈRE · PAU</span>
      <h1 class="wabi-headline">La beauté<br />de l'imparfait<br />en mouvement</h1>
      <p class="wabi-subtitle">{t.home.intro}</p>
      <a href={`${base}contact`} class="wabi-btn">
        Commencer le voyage
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="wabi-hero-right">
      <div class="wabi-circle-art">
        <div class="wabi-symbol">
          <svg viewBox="0 0 100 100" fill="none">
            <path d="M50 15 Q80 40 50 85 Q20 40 50 15" stroke="#8B9A7D" stroke-width="1" fill="none"/>
            <circle cx="50" cy="50" r="8" fill="#C4A484" fill-opacity="0.6"/>
            <path d="M30 50 H70 M50 30 V70" stroke="#B86B4C" stroke-width="0.5" stroke-opacity="0.4"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <section class="wabi-activity-section">
    <a href={activities[0].link} class="wabi-activity gymnastics">
      <span class="wabi-activity-label">{activities[0].subtitle}</span>
      <h2 class="wabi-activity-title">{activities[0].title}</h2>
      <p class="wabi-activity-desc">Un retour à l'essentiel du corps, où chaque mouvement devient conscient et significatif.</p>
      <span class="wabi-activity-cta">
        {activities[0].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="wabi-activity theatre">
      <span class="wabi-activity-label">{activities[1].subtitle}</span>
      <h2 class="wabi-activity-title">{activities[1].title}</h2>
      <p class="wabi-activity-desc">Le jeu théâtral comme chemin de connaissance de soi et d'expression authentique.</p>
      <span class="wabi-activity-cta">
        {activities[1].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>

  <section class="wabi-intro">
    <p class="wabi-intro-text">{t.home.hero.subtitle} — une invitation à explorer votre bien-être integral avec calme et présence.</p>
    <a href={`${base}about`} class="wabi-intro-link">
      Rencontre Sonia Cutri →
    </a>
  </section>

  <footer class="wabi-footer">
    <span>© 2026 Espace Bienestar</span>
    <span>Billère, France</span>
  </footer>
</div>
</ProposalLayout>
