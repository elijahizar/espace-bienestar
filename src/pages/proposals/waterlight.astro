---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');

const base = import.meta.env.BASE_URL;

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: 'Mouvement conscient',
    link: `${base}activities/gymnastics`,
    cta: 'Découvrir'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: 'Expression créative',
    link: `${base}activities/theatre`,
    cta: 'Découvrir'
  }
];
---

<ProposalLayout title="Proposition - Eau et Lumière" styleName="03 · Eau et Lumière">
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Raleway:wght@300;400;500;600&display=swap');

:root {
  --water-sky: #A8C5D9;
  --water-deep: #5B7B8C;
  --water-light: #E8F1F5;
  --water-foam: #F5FAFC;
  --water-sea: #3D6B7D;
  --water-coral: #D4917A;
}

html { scroll-behavior: smooth; }

.font-display { font-family: 'Cormorant Garamond', serif; }
.font-body { font-family: 'Raleway', sans-serif; }

.water-page {
  min-height: 100vh;
  background: var(--water-foam);
  color: var(--water-deep);
}

.water-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 4rem;
  border-bottom: 1px solid rgba(91, 123, 140, 0.15);
  background: rgba(232, 241, 245, 0.8);
  backdrop-filter: blur(8px);
}

.water-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 400;
  letter-spacing: 0.1em;
  color: var(--water-deep);
}

.water-nav {
  display: flex;
  gap: 3rem;
  font-family: 'Raleway', sans-serif;
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.05em;
}

.water-nav a {
  color: var(--water-deep);
  text-decoration: none;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.water-nav a:hover { opacity: 1; }

.water-hero {
  min-height: 85vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}

.water-hero-left {
  padding: 4rem 5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.water-kicker {
  font-family: 'Raleway', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--water-sea);
  margin-bottom: 2rem;
}

.water-headline {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.25;
  color: var(--water-deep);
  margin-bottom: 1.5rem;
}

.water-headline em {
  font-style: italic;
  color: var(--water-coral);
}

.water-subtitle {
  font-family: 'Raleway', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  color: var(--water-sea);
  max-width: 360px;
  line-height: 1.8;
  margin-bottom: 3rem;
}

.water-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Raleway', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--water-deep);
  color: var(--water-foam);
  text-decoration: none;
  padding: 1rem 2rem;
  transition: all 0.3s;
  width: fit-content;
}

.water-btn:hover {
  background: var(--water-sea);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(61, 107, 125, 0.2);
}

.water-btn svg { width: 1rem; }

.water-hero-right {
  position: relative;
  background: linear-gradient(135deg, var(--water-light) 0%, var(--water-sky) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.water-waves {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.water-wave {
  position: absolute;
  width: 200%;
  height: 100%;
  background: repeat-x;
  animation: water-wave 12s linear infinite;
}

.water-wave-1 {
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path fill="%23F5FAFC" fill-opacity="0.3" d="M0,60 C300,100 600,20 900,60 C1200,100 1200,60 1200,60 L1200,120 L0,120 Z"/></svg>');
  background-size: 600px 100px;
  animation-duration: 15s;
  opacity: 0.6;
}

.water-wave-2 {
  bottom: 20px;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path fill="%23E8F1F5" fill-opacity="0.5" d="M0,60 C300,20 600,100 900,60 C1200,20 1200,60 1200,60 L1200,120 L0,120 Z"/></svg>');
  background-size: 600px 100px;
  animation-duration: 10s;
  animation-direction: reverse;
  opacity: 0.8;
}

.water-wave-3 {
  bottom: 40px;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path fill="%23A8C5D9" fill-opacity="0.3" d="M0,60 C300,100 600,20 900,60 C1200,100 1200,60 1200,60 L1200,120 L0,120 Z"/></svg>');
  background-size: 600px 100px;
  animation-duration: 20s;
  opacity: 0.4;
}

@keyframes water-wave {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.water-sun {
  position: absolute;
  top: 20%;
  right: 15%;
  width: 80px;
  height: 80px;
  background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(212, 145, 122, 0.3) 70%, transparent 100%);
  border-radius: 50%;
  animation: water-glow 4s ease-in-out infinite;
}

@keyframes water-glow {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.1); opacity: 1; }
}

.water-activities {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.water-activity {
  position: relative;
  padding: 4rem;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  overflow: hidden;
}

.water-activity::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: transform 0.5s ease;
}

.water-activity:hover::before { transform: scale(1.02); }

.water-activity.gymnastics {
  background: linear-gradient(180deg, var(--water-light) 0%, #D4E3ED 100%);
}

.water-activity.gymnastics::before {
  background: radial-gradient(circle at 60% 40%, rgba(168, 197, 217, 0.4) 0%, transparent 50%);
}

.water-activity.theatre {
  background: linear-gradient(180deg, var(--water-deep) 0%, #3D5570 100%);
}

.water-activity.theatre::before {
  background: radial-gradient(circle at 40% 60%, rgba(212, 145, 122, 0.15) 0%, transparent 50%);
}

.water-activity-label {
  font-family: 'Raleway', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.water-activity.gymnastics .water-activity-label { color: var(--water-sea); }
.water-activity.theatre .water-activity-label { color: rgba(255,255,255,0.6); }

.water-activity-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: 1rem;
}

.water-activity.gymnastics .water-activity-title { color: var(--water-deep); }
.water-activity.theatre .water-activity-title { color: var(--water-foam); }

.water-activity-desc {
  font-family: 'Raleway', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 280px;
}

.water-activity.gymnastics .water-activity-desc { color: var(--water-sea); }
.water-activity.theatre .water-activity-desc { color: rgba(255,255,255,0.7); }

.water-activity-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Raleway', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.water-activity.gymnastics .water-activity-cta { color: var(--water-deep); }
.water-activity.theatre .water-activity-cta { color: var(--water-coral); }

.water-activity-cta svg {
  width: 1.25rem;
  transition: transform 0.3s;
}

.water-activity:hover .water-activity-cta svg { transform: translateX(6px); }

.water-intro {
  padding: 6rem 4rem;
  background: var(--water-foam);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: center;
  border-top: 1px solid rgba(91, 123, 140, 0.1);
}

.water-intro-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.35rem;
  font-weight: 300;
  font-style: italic;
  color: var(--water-deep);
  line-height: 1.8;
}

.water-intro-links {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.water-intro-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: 'Raleway', sans-serif;
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--water-deep);
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid rgba(91, 123, 140, 0.2);
  transition: all 0.2s;
}

.water-intro-link:hover {
  color: var(--water-sea);
  padding-left: 0.5rem;
}

.water-intro-link svg { width: 1.25rem; }

.water-footer {
  padding: 2rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--water-foam);
  border-top: 1px solid rgba(91, 123, 140, 0.1);
  font-family: 'Raleway', sans-serif;
  font-size: 0.75rem;
  color: var(--water-sea);
}

@media (max-width: 900px) {
  .water-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
  .water-nav { gap: 1.5rem; }
  .water-hero { grid-template-columns: 1fr; }
  .water-hero-left { padding: 5rem 1.5rem 3rem; }
  .water-hero-right { min-height: 40vh; }
  .water-activities { grid-template-columns: 1fr; }
  .water-activity { padding: 3rem 1.5rem; }
  .water-intro { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 2rem; }
  .water-footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>

<div class="water-page">
  <header class="water-header">
    <div class="water-logo">Espace Bienestar</div>
    <nav class="water-nav">
<a href={base}>Accueil</a>
    <a href={`${base}activities`}>Activités</a>
    <a href={`${base}about`}>À propos</a>
    <a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <section class="water-hero">
    <div class="water-hero-left">
      <span class="water-kicker">Billère · Pau · France</span>
      <h1 class="water-headline">
        Couler avec<br /><em>sérénité</em><br />et calme
      </h1>
      <p class="water-subtitle">{t.home.intro}</p>
      <a href={`${base}contact`} class="water-btn">
        Commencer
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="water-hero-right">
      <div class="water-waves">
        <div class="water-wave water-wave-1"></div>
        <div class="water-wave water-wave-2"></div>
        <div class="water-wave water-wave-3"></div>
      </div>
      <div class="water-sun"></div>
    </div>
  </section>

  <section class="water-activities">
    <a href={activities[0].link} class="water-activity gymnastics">
      <span class="water-activity-label">{activities[0].subtitle}</span>
      <h2 class="water-activity-title">{activities[0].title}</h2>
      <p class="water-activity-desc">Le mouvement conscient comme une rivière qui coule vers le calme.</p>
      <span class="water-activity-cta">
        {activities[0].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="water-activity theatre">
      <span class="water-activity-label">{activities[1].subtitle}</span>
      <h2 class="water-activity-title">{activities[1].title}</h2>
      <p class="water-activity-desc">L'expression créative comme une vague qui trouve sa forme.</p>
      <span class="water-activity-cta">
        {activities[1].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>

  <section class="water-intro">
    <p class="water-intro-text">{t.home.hero.subtitle} — Un espace où l'eau enseigne le chemin.</p>
    <div class="water-intro-links">
      <a href={`${base}about`} class="water-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Rencontrer Sonia
      </a>
      <a href={`${base}schedule`} class="water-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Voir les horaires
      </a>
    </div>
  </section>

  <footer class="water-footer">
    <span>© 2026 Espace Bienestar</span>
    <span>Billère, France</span>
  </footer>
</div>
</ProposalLayout>
