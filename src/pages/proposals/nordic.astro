---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');
const base = import.meta.env.BASE_URL;

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: 'Mouvement conscient',
    link: `${base}activities/gymnastics`,
    cta: 'Découvrir'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: 'Expression créative',
    link: `${base}activities/theatre`,
    cta: 'Découvrir'
  }
];
---

<ProposalLayout title="Proposition - Nordique" styleName="05 · Nordique">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

:root {
  --nordic-ice: #E0F2F1;
  --nordic-soft-blue: #A7C7E7;
  --nordic-deep: #4A6572;
  --nordic-white: #FFFFFF;
  --nordic-frost: #D4E8F0;
  --nordic-shadow: #2C3E50;
  --nordic-mist: #E8F0F5;
}

html { scroll-behavior: smooth; }

.nordic-page {
  min-height: 100vh;
  background: var(--nordic-white);
  color: var(--nordic-deep);
}

.nordic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 4rem;
  background: var(--nordic-white);
  border-bottom: 1px solid var(--nordic-ice);
}

.nordic-logo {
  font-family: 'Inter', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--nordic-deep);
}

.nordic-nav {
  display: flex;
  gap: 3rem;
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 400;
}

.nordic-nav a {
  color: var(--nordic-deep);
  text-decoration: none;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.nordic-nav a:hover { opacity: 1; }

.nordic-hero {
  min-height: 85vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.nordic-hero-left {
  padding: 4rem 5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--nordic-white);
}

.nordic-kicker {
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--nordic-soft-blue);
  margin-bottom: 2rem;
}

.nordic-headline {
  font-family: 'Inter', sans-serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.25;
  color: var(--nordic-shadow);
  margin-bottom: 1.5rem;
}

.nordic-headline em {
  font-style: italic;
  font-weight: 300;
  color: var(--nordic-soft-blue);
}

.nordic-subtitle {
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  color: var(--nordic-deep);
  opacity: 0.7;
  max-width: 360px;
  line-height: 1.8;
  margin-bottom: 3rem;
}

.nordic-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  background: var(--nordic-deep);
  color: var(--nordic-white);
  text-decoration: none;
  padding: 1rem 2rem;
  transition: all 0.3s;
  width: fit-content;
}

.nordic-btn:hover {
  background: var(--nordic-shadow);
}

.nordic-btn svg { width: 1rem; }

.nordic-hero-right {
  position: relative;
  background: linear-gradient(135deg, var(--nordic-ice) 0%, var(--nordic-soft-blue) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.nordic-hero-right::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 40%, rgba(255,255,255,0.3) 0%, transparent 40%),
    radial-gradient(circle at 70% 60%, rgba(74,101,114,0.1) 0%, transparent 35%);
}

.nordic-crystal {
  position: relative;
  width: 160px;
  height: 200px;
}

.nordic-crystal-shape {
  position: absolute;
  border: 1px solid rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.1);
}

.nordic-crystal-shape:nth-child(1) {
  width: 80px;
  height: 120px;
  top: 40px;
  left: 40px;
  transform: rotate(15deg);
}

.nordic-crystal-shape:nth-child(2) {
  width: 60px;
  height: 90px;
  top: 10px;
  left: 70px;
  transform: rotate(-10deg);
  border-color: rgba(255,255,255,0.3);
}

.nordic-crystal-shape:nth-child(3) {
  width: 50px;
  height: 80px;
  top: 80px;
  left: 20px;
  transform: rotate(25deg);
  border-color: rgba(255,255,255,0.4);
  background: rgba(167,199,231,0.1);
}

.nordic-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.15);
}

.nordic-ring:nth-child(4) { width: 140px; height: 140px; }
.nordic-ring:nth-child(5) { width: 200px; height: 200px; border-color: rgba(255,255,255,0.08); }
.nordic-ring:nth-child(6) { width: 260px; height: 260px; border-color: rgba(255,255,255,0.05); }

.nordic-activities {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.nordic-activity {
  position: relative;
  padding: 4rem;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  overflow: hidden;
}

.nordic-activity::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: transform 0.5s ease;
}

.nordic-activity:hover::before { transform: scale(1.02); }

.nordic-activity.gymnastics {
  background: linear-gradient(180deg, var(--nordic-ice) 0%, var(--nordic-soft-blue) 100%);
}

.nordic-activity.gymnastics::before {
  background: radial-gradient(circle at 60% 30%, rgba(255,255,255,0.3) 0%, transparent 50%);
}

.nordic-activity.theatre {
  background: linear-gradient(180deg, var(--nordic-deep) 0%, var(--nordic-shadow) 100%);
}

.nordic-activity.theatre::before {
  background: radial-gradient(circle at 40% 70%, rgba(167,199,231,0.15) 0%, transparent 40%);
}

.nordic-activity-label {
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.nordic-activity.gymnastics .nordic-activity-label { color: var(--nordic-deep); opacity: 0.7; }
.nordic-activity.theatre .nordic-activity-label { color: var(--nordic-frost); }

.nordic-activity-title {
  font-family: 'Inter', sans-serif;
  font-size: 2rem;
  font-weight: 300;
  margin-bottom: 1rem;
}

.nordic-activity.gymnastics .nordic-activity-title { color: var(--nordic-shadow); }
.nordic-activity.theatre .nordic-activity-title { color: var(--nordic-white); }

.nordic-activity-desc {
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 280px;
}

.nordic-activity.gymnastics .nordic-activity-desc { color: var(--nordic-deep); }
.nordic-activity.theatre .nordic-activity-desc { color: rgba(255,255,255,0.6); }

.nordic-activity-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}

.nordic-activity.gymnastics .nordic-activity-cta { color: var(--nordic-deep); }
.nordic-activity.theatre .nordic-activity-cta { color: var(--nordic-soft-blue); }

.nordic-activity-cta svg {
  width: 1.25rem;
  transition: transform 0.3s;
}

.nordic-activity:hover .nordic-activity-cta svg { transform: translateX(6px); }

.nordic-intro {
  padding: 6rem 4rem;
  background: var(--nordic-mist);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: center;
  border-top: 1px solid var(--nordic-ice);
}

.nordic-intro-text {
  font-family: 'Inter', sans-serif;
  font-size: 1.35rem;
  font-weight: 300;
  font-style: italic;
  color: var(--nordic-shadow);
  line-height: 1.8;
}

.nordic-intro-links {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.nordic-intro-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--nordic-deep);
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--nordic-ice);
  transition: all 0.2s;
}

.nordic-intro-link:hover {
  color: var(--nordic-soft-blue);
  padding-left: 0.5rem;
}

.nordic-intro-link svg { width: 1.25rem; }

.nordic-footer {
  padding: 2rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--nordic-white);
  border-top: 1px solid var(--nordic-ice);
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 0.75rem;
  color: var(--nordic-deep);
  opacity: 0.5;
}

@media (max-width: 900px) {
  .nordic-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
  .nordic-nav { gap: 1.5rem; }
  .nordic-hero { grid-template-columns: 1fr; }
  .nordic-hero-left { padding: 5rem 1.5rem 3rem; }
  .nordic-hero-right { min-height: 40vh; }
  .nordic-activities { grid-template-columns: 1fr; }
  .nordic-activity { padding: 3rem 1.5rem; }
  .nordic-intro { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 2rem; }
  .nordic-footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>

<div class="nordic-page">
  <header class="nordic-header">
    <div class="nordic-logo">Espace Bienestar</div>
    <nav class="nordic-nav">
<a href={base}>Accueil</a>
<a href={`${base}activities`}>Activités</a>
<a href={`${base}about`}>À propos</a>
<a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <section class="nordic-hero">
    <div class="nordic-hero-left">
      <span class="nordic-kicker">Calme nordique · Billère · France</span>
      <h1 class="nordic-headline">
        Sérénité<br /><em>scandinave</em>
      </h1>
      <p class="nordic-subtitle">{t.home.intro}</p>
      <a href={`${base}contact`} class="nordic-btn">
        Commencer
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="nordic-hero-right">
      <div class="nordic-crystal">
        <div class="nordic-crystal-shape"></div>
        <div class="nordic-crystal-shape"></div>
        <div class="nordic-crystal-shape"></div>
        <div class="nordic-ring"></div>
        <div class="nordic-ring"></div>
        <div class="nordic-ring"></div>
      </div>
    </div>
  </section>

  <section class="nordic-activities">
    <a href={activities[0].link} class="nordic-activity gymnastics">
      <span class="nordic-activity-label">{activities[0].subtitle}</span>
      <h2 class="nordic-activity-title">{activities[0].title}</h2>
      <p class="nordic-activity-desc">Le mouvement conscient comme la glace qui coule avec grâce.</p>
      <span class="nordic-activity-cta">
        {activities[0].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="nordic-activity theatre">
      <span class="nordic-activity-label">{activities[1].subtitle}</span>
      <h2 class="nordic-activity-title">{activities[1].title}</h2>
      <p class="nordic-activity-desc">L'expression créative comme une aurore dans la nuit polaire.</p>
      <span class="nordic-activity-cta">
        {activities[1].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>

  <section class="nordic-intro">
    <p class="nordic-intro-text">{t.home.hero.subtitle} — Le calme du nord comme chemin vers le bien-être.</p>
    <div class="nordic-intro-links">
      <a href={`${base}about`} class="nordic-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Rencontrer Sonia
      </a>
      <a href={`${base}schedule`} class="nordic-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Voir les horaires
      </a>
    </div>
  </section>

  <footer class="nordic-footer">
    <span>© 2026 Espace Bienestar</span>
    <span>Billère, France</span>
  </footer>
</div>
</ProposalLayout>
