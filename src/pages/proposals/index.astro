---
const base = import.meta.env.BASE_URL;

const proposals = [
  { id: 'editorial', name: 'Éditorial', number: '01', fonts: 'Cormorant Garamond + Instrument Sans', palette: 'Crème, Sienne, Terracotta', colors: ['#F7F4EF', '#8B4513', '#C4785A'] },
  { id: 'wabisabi', name: 'Wabi-Sabi', number: '02', fonts: 'Zen Old Mincho + Shippori Mincho', palette: 'Argile, Sauge, Crème', colors: ['#C4A484', '#8B9A7D', '#F5F0E8'] },
  { id: 'waterlight', name: 'Eau et Lumière', number: '03', fonts: 'Cormorant Garamond + Raleway', palette: 'Ciel, Mer Profonde, Corail', colors: ['#A8C5D9', '#5B7B8C', '#D4917A'] },
  { id: 'forest', name: 'Forêt', number: '04', fonts: 'Libre Baskerville + Proza Libre', palette: 'Vert Forêt, Écorce, Crème', colors: ['#1A2E1A', '#6B8E5A', '#F5F2E8'] },
  { id: 'nordic', name: 'Nordique', number: '05', fonts: 'Inter + IBM Plex Sans', palette: 'Glace, Bleu Doux, Ardoise', colors: ['#E0F2F1', '#A7C7E7', '#4A6572'] },
  { id: 'mediterranean', name: 'Méditerranée', number: '06', fonts: 'Playfair Display + Source Sans Pro', palette: 'Sable Chaud, Olive, Or', colors: ['#F4E1C1', '#C9A66B', '#D4B896'] },
  { id: 'warmdesert', name: 'Désert Chaud', number: '07', fonts: 'Playfair Display + Source Sans Pro', palette: 'Terracotta, Sable, Violet Clair', colors: ['#C4956A', '#E8D5C4', '#C8B8D9'] },
  { id: 'botanical', name: 'Botanique', number: '08', fonts: 'Petrona + Nunito', palette: 'Vert Feuille, Sauge, Pétale', colors: ['#4A5D4A', '#9AAF9A', '#D4A5A5'] },
  { id: 'aurora', name: 'Aurora', number: '09', fonts: 'Cormorant Garamond + Inter', palette: 'Bleu Polaire, Brume, Violet Aurora', colors: ['#D3E8FF', '#8FA9C7', '#E0B0FF'] },
  { id: 'artisan', name: 'Artisan Terre', number: '10', fonts: 'Fraunces + DM Sans', palette: 'Ambre Chaud, Argile, Lin', colors: ['#C8956C', '#A67B5B', '#EDE4D3'] },
];

const layouts = [
  { id: 'forest-story', name: 'Forêt — Scroll Narratif', number: 'L1', fonts: 'Libre Baskerville + Proza Libre', palette: 'Même style #04, mise en page immersive', colors: ['#1A2E1A', '#6B8E5A', '#F5F2E8'], tag: 'Layout A' },
  { id: 'nordic-bento', name: 'Nordique — Bento Grid', number: 'L2', fonts: 'Inter + IBM Plex Sans', palette: 'Même style #05, grille modulaire', colors: ['#E0F2F1', '#A7C7E7', '#4A6572'], tag: 'Layout B' },
];
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Propositions — Espace Bienestar</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      background: #FAFAF8;
      color: #1A1A1A;
      font-family: 'DM Sans', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .gallery-header {
      background: #1A1A1A;
      padding: 3rem 2rem 2.5rem;
      text-align: center;
    }

    .gallery-header-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: #FAFAF8;
      margin-bottom: 0.5rem;
    }

    .gallery-header-sub {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #767676;
    }

    .gallery-container {
      max-width: 1120px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .proposal-card {
      display: block;
      background: #FFFFFF;
      border: 1px solid #E8E6E1;
      border-radius: 8px;
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s;
      cursor: pointer;
      position: relative;
    }

    .proposal-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
      border-color: #D0CEC9;
    }

    .proposal-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.25rem;
    }

    .proposal-number {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: #999;
    }

    .proposal-color-dots {
      display: flex;
      gap: 6px;
    }

    .proposal-color-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .proposal-name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #1A1A1A;
      margin-bottom: 0.5rem;
    }

    .proposal-fonts {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      color: #767676;
      margin-bottom: 0.75rem;
      line-height: 1.5;
    }

    .proposal-palette {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      color: #999;
      text-transform: uppercase;
    }

    .proposal-arrow {
      position: absolute;
      bottom: 2rem;
      right: 2rem;
      width: 20px;
      height: 20px;
      opacity: 0;
      transform: translateX(-4px);
      transition: opacity 0.3s, transform 0.3s;
    }

    .proposal-card:hover .proposal-arrow {
      opacity: 0.4;
      transform: translateX(0);
    }

.gallery-footer {
  text-align: center;
  padding: 3rem 2rem 2.5rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: #999;
}

/* Layout alternatives section */
.layout-section-label {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #767676;
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid #E8E6E1;
}

.layout-tag {
  display: inline-block;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: #1A1A1A;
  color: #FAFAF8;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  margin-left: 0.5rem;
  vertical-align: middle;
}

    @media (max-width: 700px) {
      .gallery-header { padding: 2.25rem 1.5rem 2rem; }
      .gallery-container { padding: 2rem 1.25rem 3rem; }
      .gallery-grid { grid-template-columns: 1fr; gap: 1rem; }
      .proposal-card { padding: 1.5rem; }
      .proposal-arrow { display: none; }
    }

    @media (min-width: 960px) {
      .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</head>
<body>
  <header class="gallery-header">
    <h1 class="gallery-header-title">Espace Bienestar</h1>
    <p class="gallery-header-sub">Choisissez votre style</p>
  </header>

  <main class="gallery-container">
    <div class="gallery-grid">
      {proposals.map((p) => (
      <a href={`${base}proposals/${p.id}`} class="proposal-card">
        <div class="proposal-card-top">
          <span class="proposal-number">{p.number}</span>
          <div class="proposal-color-dots">
            {p.colors.map((c) => (
            <span class="proposal-color-dot" style={`background-color: ${c};`} />
            ))}
          </div>
        </div>
        <h2 class="proposal-name">{p.name}</h2>
        <p class="proposal-fonts">{p.fonts}</p>
        <p class="proposal-palette">{p.palette}</p>
        <svg class="proposal-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
      ))}
    </div>

    <div class="layout-section-label">Alternatives de mise en page <span style="font-weight:400; color:#999; letter-spacing:0.05em; text-transform:none;">— même style, disposition différente</span></div>
    <div class="gallery-grid">
      {layouts.map((l) => (
      <a href={`${base}proposals/${l.id}`} class="proposal-card">
        <div class="proposal-card-top">
          <span class="proposal-number">{l.number} <span class="layout-tag">{l.tag}</span></span>
          <div class="proposal-color-dots">
            {l.colors.map((c) => (
            <span class="proposal-color-dot" style={`background-color: ${c};`} />
            ))}
          </div>
        </div>
        <h2 class="proposal-name">{l.name}</h2>
        <p class="proposal-fonts">{l.fonts}</p>
        <p class="proposal-palette">{l.palette}</p>
        <svg class="proposal-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
      ))}
    </div>
  </main>

  <footer class="gallery-footer">
    © 2026 Espace Bienestar — Billère, France
  </footer>
</body>
</html>
