---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');

const base = import.meta.env.BASE_URL;
---

<ProposalLayout title="Proposition - Forêt (Scroll Narratif)" styleName="04 · Forêt — Scroll Narratif">
<style>
@import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Proza+Libre:wght@400;500;600&display=swap');

:root {
--forest-dark: #1A2E1A;
--forest-green: #3D5C3D;
--forest-moss: #6B8E5A;
--forest-light: #A8C49A;
--forest-cream: #F5F2E8;
--forest-bark: #4A3728;
--forest-mist: #D4DFD0;
}

html { scroll-behavior: smooth; }

.font-display { font-family: 'Libre Baskerville', serif; }
.font-body { font-family: 'Proza Libre', sans-serif; }

.story-page {
background: var(--forest-cream);
color: var(--forest-dark);
}

.story-header {
display: flex;
justify-content: space-between;
align-items: center;
padding: 1.25rem 4rem;
background: var(--forest-dark);
color: var(--forest-cream);
position: relative;
z-index: 10;
}

.story-logo {
font-family: 'Libre Baskerville', serif;
font-size: 1.2rem;
font-weight: 400;
letter-spacing: 0.05em;
}

.story-nav {
display: flex;
gap: 3rem;
font-family: 'Proza Libre', sans-serif;
font-size: 0.8rem;
font-weight: 400;
}

.story-nav a {
color: var(--forest-light);
text-decoration: none;
transition: color 0.2s;
}

.story-nav a:hover { color: var(--forest-cream); }

/* ── HERO: Full viewport, centered ── */
.story-hero {
position: relative;
min-height: 100vh;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
text-align: center;
background: linear-gradient(160deg, var(--forest-cream) 0%, var(--forest-mist) 40%, rgba(107,142,90,0.12) 100%);
overflow: hidden;
padding: 4rem 2rem;
}

.story-hero-kicker {
font-family: 'Proza Libre', sans-serif;
font-size: 0.7rem;
font-weight: 500;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(--forest-moss);
margin-bottom: 2rem;
}

.story-hero-headline {
font-family: 'Libre Baskerville', serif;
font-size: clamp(3rem, 7vw, 6.5rem);
font-weight: 400;
line-height: 1.15;
color: var(--forest-dark);
margin-bottom: 1.5rem;
}

.story-hero-headline em {
font-style: italic;
color: var(--forest-moss);
}

.story-hero-subtitle {
font-family: 'Proza Libre', sans-serif;
font-size: 1.05rem;
font-weight: 400;
color: var(--forest-green);
max-width: 520px;
line-height: 1.9;
margin-bottom: 2.5rem;
}

.story-hero-btn {
display: inline-flex;
align-items: center;
gap: 0.75rem;
font-family: 'Proza Libre', sans-serif;
font-size: 0.85rem;
font-weight: 500;
letter-spacing: 0.05em;
background: var(--forest-green);
color: var(--forest-cream);
text-decoration: none;
padding: 1rem 2.5rem;
border-radius: 999px;
transition: all 0.3s;
}

.story-hero-btn:hover {
background: var(--forest-dark);
}

.story-hero-btn svg { width: 1rem; }

.story-scroll-hint {
position: absolute;
bottom: 2.5rem;
left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 0.5rem;
}

.story-scroll-hint-line {
width: 1px;
height: 40px;
background: var(--forest-moss);
opacity: 0.4;
animation: scrollPulse 2s infinite;
}

@keyframes scrollPulse {
0%, 100% { opacity: 0.15; transform: scaleY(0.6); transform-origin: top; }
50% { opacity: 0.5; transform: scaleY(1); }
}

/* ── Floating shapes ── */
.story-shape {
position: absolute;
border-radius: 50%;
pointer-events: none;
will-change: transform;
}

.story-shape-1 {
width: 180px;
height: 180px;
border: 1px solid rgba(107,142,90,0.15);
top: 12%;
right: 8%;
}

.story-shape-2 {
width: 120px;
height: 120px;
background: rgba(107,142,90,0.06);
top: 20%;
left: 6%;
}

.story-shape-3 {
width: 80px;
height: 80px;
border: 1px solid rgba(168,196,154,0.2);
bottom: 22%;
right: 15%;
}

.story-shape-4 {
width: 40px;
height: 40px;
background: rgba(107,142,90,0.1);
bottom: 30%;
left: 12%;
}

.story-shape-5 {
width: 60px;
height: 60px;
border: 1px solid rgba(107,142,90,0.12);
top: 55%;
left: 25%;
}

/* ── Activity bands ── */
.story-band {
display: grid;
grid-template-columns: 1fr 1fr;
min-height: 70vh;
position: relative;
overflow: hidden;
}

.story-band-reverse {
grid-template-columns: 1fr 1fr;
}

.story-band-text {
padding: 4rem 5rem;
display: flex;
flex-direction: column;
justify-content: center;
}

.story-band-art {
position: relative;
display: flex;
align-items: center;
justify-content: center;
overflow: hidden;
}

.story-band-label {
font-family: 'Proza Libre', sans-serif;
font-size: 0.7rem;
font-weight: 500;
letter-spacing: 0.2em;
text-transform: uppercase;
margin-bottom: 1rem;
}

.story-band-title {
font-family: 'Libre Baskerville', serif;
font-size: clamp(2rem, 4vw, 2.75rem);
font-weight: 400;
line-height: 1.25;
margin-bottom: 1.25rem;
}

.story-band-desc {
font-family: 'Proza Libre', sans-serif;
font-size: 0.9rem;
line-height: 1.8;
margin-bottom: 2rem;
max-width: 340px;
}

.story-band-cta {
display: inline-flex;
align-items: center;
gap: 0.75rem;
font-family: 'Proza Libre', sans-serif;
font-size: 0.8rem;
font-weight: 500;
letter-spacing: 0.05em;
text-decoration: none;
transition: gap 0.3s;
}

.story-band-cta svg {
width: 1.25rem;
transition: transform 0.3s;
}

.story-band-cta:hover svg {
transform: translateX(6px);
}

/* ── Gymnastics band (light, text left) ── */
.story-gym-band {
background: var(--forest-cream);
}

.story-gym-band .story-band-text {
color: var(--forest-dark);
}

.story-gym-band .story-band-label {
color: var(--forest-moss);
}

.story-gym-band .story-band-desc {
color: var(--forest-green);
}

.story-gym-band .story-band-cta {
color: var(--forest-dark);
}

.story-gym-band .story-band-art {
background: linear-gradient(135deg, var(--forest-mist) 0%, var(--forest-light) 50%, var(--forest-moss) 100%);
}

.story-gym-band .story-band-art::before {
content: '';
position: absolute;
inset: 0;
background:
radial-gradient(circle at 50% 40%, rgba(255,255,255,0.25) 0%, transparent 40%),
radial-gradient(circle at 20% 70%, rgba(107,142,90,0.15) 0%, transparent 30%);
}

/* Gym art: tree illustration */
.story-tree {
position: relative;
width: 180px;
height: 260px;
}

.story-tree-trunk {
position: absolute;
bottom: 0;
left: 50%;
transform: translateX(-50%);
width: 16px;
height: 100px;
background: var(--forest-bark);
opacity: 0.5;
border-radius: 4px;
}

.story-tree-canopy {
position: absolute;
bottom: 60px;
left: 50%;
transform: translateX(-50%);
}

.story-tree-canopy::before,
.story-tree-canopy::after,
.story-tree-canopy span {
content: '';
position: absolute;
border-radius: 50%;
background: var(--forest-light);
opacity: 0.35;
}

.story-tree-canopy::before { width: 110px; height: 110px; top: 0; left: -55px; }
.story-tree-canopy::after { width: 90px; height: 90px; top: -25px; left: -45px; }
.story-tree-canopy span { width: 70px; height: 70px; top: -50px; left: -35px; }

/* ── Theatre band (dark, text right) ── */
.story-theatre-band {
background: var(--forest-dark);
}

.story-theatre-band .story-band-text {
color: var(--forest-cream);
}

.story-theatre-band .story-band-label {
color: var(--forest-light);
}

.story-theatre-band .story-band-desc {
color: var(--forest-mist);
}

.story-theatre-band .story-band-cta {
color: var(--forest-light);
}

.story-theatre-band .story-band-art {
background: linear-gradient(135deg, var(--forest-dark) 0%, #0F1F0F 60%, rgba(107,142,90,0.15) 100%);
}

.story-theatre-band .story-band-art::before {
content: '';
position: absolute;
inset: 0;
background:
radial-gradient(circle at 60% 30%, rgba(107,142,90,0.2) 0%, transparent 35%),
radial-gradient(circle at 30% 80%, rgba(168,196,154,0.1) 0%, transparent 25%);
}

/* Theatre art: moonlight rings */
.story-moon {
position: relative;
width: 120px;
height: 120px;
}

.story-moon-core {
width: 60px;
height: 60px;
border-radius: 50%;
background: rgba(168,196,154,0.2);
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
}

.story-moon-ring {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
border-radius: 50%;
border: 1px solid rgba(168,196,154,0.15);
}

.story-moon-ring:nth-child(2) { width: 90px; height: 90px; }
.story-moon-ring:nth-child(3) { width: 120px; height: 120px; border-color: rgba(168,196,154,0.08); }

/* ── Chapter divider ── */
.story-divider {
display: flex;
align-items: center;
justify-content: center;
padding: 4rem 2rem;
background: var(--forest-cream);
}

.story-divider-line {
width: 80px;
height: 1px;
background: var(--forest-mist);
position: relative;
}

.story-divider-dot {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
width: 8px;
height: 8px;
border-radius: 50%;
background: var(--forest-moss);
}

/* ── Philosophy interlude ── */
.story-interlude {
min-height: 50vh;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
text-align: center;
padding: 6rem 2rem;
background: rgba(107,142,90,0.06);
position: relative;
}

.story-interlude::before {
content: '';
position: absolute;
inset: 0;
background:
radial-gradient(circle at 30% 50%, rgba(107,142,90,0.04) 0%, transparent 50%),
radial-gradient(circle at 70% 40%, rgba(168,196,154,0.03) 0%, transparent 40%);
pointer-events: none;
}

.story-interlude-quote {
font-family: 'Libre Baskerville', serif;
font-size: 1.5rem;
font-weight: 400;
font-style: italic;
color: var(--forest-dark);
line-height: 1.85;
max-width: 600px;
margin-bottom: 2.5rem;
position: relative;
z-index: 1;
}

.story-interlude-attr {
font-family: 'Proza Libre', sans-serif;
font-size: 0.85rem;
color: var(--forest-green);
margin-bottom: 2rem;
}

.story-interlude-links {
display: flex;
flex-direction: column;
gap: 1rem;
position: relative;
z-index: 1;
}

.story-interlude-link {
display: inline-flex;
align-items: center;
gap: 0.75rem;
font-family: 'Proza Libre', sans-serif;
font-size: 0.85rem;
font-weight: 400;
color: var(--forest-dark);
text-decoration: none;
transition: color 0.2s, gap 0.2s;
}

.story-interlude-link:hover {
color: var(--forest-moss);
gap: 1rem;
}

.story-interlude-link svg { width: 1rem; }

/* ── Footer ── */
.story-footer {
padding: 2rem 4rem;
display: flex;
justify-content: space-between;
align-items: center;
background: var(--forest-dark);
color: var(--forest-light);
font-family: 'Proza Libre', sans-serif;
font-size: 0.75rem;
}

/* ── Scroll reveal ── */
.story-reveal {
opacity: 0;
transform: translateY(30px);
transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

.story-reveal.story-revealed {
opacity: 1;
transform: translateY(0);
}

.story-reveal-delay-1 { transition-delay: 0.1s; }
.story-reveal-delay-2 { transition-delay: 0.2s; }
.story-reveal-delay-3 { transition-delay: 0.3s; }

@media (prefers-reduced-motion: reduce) {
.story-reveal { opacity: 1; transform: none; transition: none; }
.story-scroll-hint-line { animation: none; opacity: 0.3; }
.story-shape { display: none; }
}

/* ── Responsive ── */
@media (max-width: 900px) {
.story-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
.story-nav { gap: 1.5rem; }
.story-hero { padding: 5rem 1.5rem 6rem; }
.story-hero-headline { font-size: clamp(2.2rem, 9vw, 3.5rem); }
.story-band { grid-template-columns: 1fr; min-height: auto; }
.story-band-art { min-height: 35vh; order: -1; }
.story-band-reverse .story-band-art { order: -1; }
.story-band-text { padding: 3rem 1.5rem; }
.story-interlude { padding: 4rem 1.5rem; min-height: auto; }
.story-interlude-quote { font-size: 1.25rem; }
.story-divider { padding: 2rem 1.5rem; }
.story-footer { flex-direction: column; gap: 1rem; text-align: center; padding: 1.5rem; }
}

@media (max-width: 600px) {
.story-shape { display: none; }
.story-scroll-hint { display: none; }
}
</style>

<div class="story-page">
<header class="story-header">
<div class="story-logo">Espace Bienestar</div>
<nav class="story-nav">
<a href={base}>Accueil</a>
    <a href={`${base}activities`}>Activités</a>
    <a href={`${base}about`}>À propos</a>
    <a href={`${base}contact`}>Contact</a>
</nav>
</header>

<section class="story-hero">
<div class="story-shape story-shape-1"></div>
<div class="story-shape story-shape-2"></div>
<div class="story-shape story-shape-3"></div>
<div class="story-shape story-shape-4"></div>
<div class="story-shape story-shape-5"></div>

<span class="story-hero-kicker">Shinrin-yoku · Billère · France</span>
<h1 class="story-hero-headline">
Connexion<br /><em>avec la</em><br />nature
</h1>
<p class="story-hero-subtitle">{t.home.intro}</p>
<a href={`${base}contact`} class="story-hero-btn">
Commencer le voyage
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</a>

<div class="story-scroll-hint">
<div class="story-scroll-hint-line"></div>
</div>
</section>

<section class="story-gym-band story-band">
<div class="story-band-text story-reveal">
<span class="story-band-label">Mouvement conscient</span>
<h2 class="story-band-title">{t.activities.gymnastics.title}</h2>
<p class="story-band-desc">Le mouvement conscient comme les feuilles qui dansent avec le vent, un voyage intérieur à travers le corps.</p>
<a href={`${base}activities/gymnastics`} class="story-band-cta">
Découvrir
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</a>
</div>
<div class="story-band-art story-reveal story-reveal-delay-1">
<div class="story-tree">
<div class="story-tree-trunk"></div>
<div class="story-tree-canopy"><span></span></div>
</div>
</div>
</section>

<div class="story-divider">
<div class="story-divider-line">
<div class="story-divider-dot"></div>
</div>
</div>

<section class="story-theatre-band story-band story-band-reverse">
<div class="story-band-art story-reveal story-reveal-delay-1">
<div class="story-moon">
<div class="story-moon-core"></div>
<div class="story-moon-ring"></div>
<div class="story-moon-ring"></div>
</div>
</div>
<div class="story-band-text story-reveal story-reveal-delay-2">
<span class="story-band-label">Expression créative</span>
<h2 class="story-band-title">{t.activities.theatre.title}</h2>
<p class="story-band-desc">L'expression théâtrale comme l'écho de la forêt, la voix qui trouve sa vérité dans l'ombre.</p>
<a href={`${base}activities/theatre`} class="story-band-cta">
Découvrir
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</a>
</div>
</section>

<section class="story-interlude story-reveal">
<p class="story-interlude-quote">{t.home.hero.subtitle} — Là où la forêt enseigne l'art de la présence, chaque souffle devient un pas vers l'harmonie.</p>
<span class="story-interlude-attr">— Sonia Cutri</span>
<div class="story-interlude-links">
<a href={`${base}about`} class="story-interlude-link">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
Rencontrer Sonia
</a>
<a href={`${base}schedule`} class="story-interlude-link">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
Voir les horaires
</a>
</div>
</section>

<footer class="story-footer">
<span>© 2026 Espace Bienestar</span>
<span>Billère, France</span>
</footer>
</div>

<script>
function initScrollReveal() {
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
if (prefersReducedMotion) {
document.querySelectorAll('.story-reveal').forEach(el => el.classList.add('story-revealed'));
return;
}

const observer = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
entry.target.classList.add('story-revealed');
observer.unobserve(entry.target);
}
});
}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.story-reveal').forEach(el => observer.observe(el));
}

function initParallax() {
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
if (prefersReducedMotion) return;

const shapes = document.querySelectorAll('.story-shape');
let ticking = false;

window.addEventListener('scroll', () => {
if (!ticking) {
requestAnimationFrame(() => {
const scrollY = window.scrollY;
shapes.forEach((shape, i) => {
const speed = 0.15 + (i * 0.05);
shape.style.transform = `translateY(${scrollY * speed}px)`;
});
ticking = false;
});
ticking = true;
}
}, { passive: true });
}

function initScrollHint() {
const hint = document.querySelector('.story-scroll-hint');
if (!hint) return;

const hero = document.querySelector('.story-hero');
const observer = new IntersectionObserver(([entry]) => {
hint.style.opacity = entry.isIntersecting ? '1' : '0';
hint.style.transition = 'opacity 0.5s';
}, { threshold: 0.3 });

observer.observe(hero);
}

document.addEventListener('DOMContentLoaded', () => {
initScrollReveal();
initParallax();
initScrollHint();
});
</script>
</ProposalLayout>
