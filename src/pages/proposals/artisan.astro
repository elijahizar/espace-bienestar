---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');

const base = import.meta.env.BASE_URL;

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: 'Mouvement conscient',
    link: `${base}activities/gymnastics`,
    cta: 'Découvrir'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: 'Expression créative',
    link: `${base}activities/theatre`,
    cta: 'Découvrir'
  }
];
---

<ProposalLayout title="Proposition - Artisan Terre" styleName="10 · Artisan Terre">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap');

:root {
  --artisan-amber: #C8956C;
  --artisan-clay: #A67B5B;
  --artisan-linen: #EDE4D3;
  --artisan-earth: #6B4C3B;
  --artisan-cream: #FAF5EE;
  --artisan-warm: #D4BFA8;
  --artisan-sage: #8B9A7D;
  --artisan-ink: #2D2318;
}

html { scroll-behavior: smooth; }

.artisan-page {
  min-height: 100vh;
  background: var(--artisan-cream);
  color: var(--artisan-ink);
}

.artisan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 4rem;
  background: var(--artisan-cream);
  border-bottom: 1px solid var(--artisan-warm);
}

.artisan-logo {
  font-family: 'Fraunces', serif;
  font-size: 1.3rem;
  font-weight: 400;
  letter-spacing: 0.03em;
  color: var(--artisan-earth);
}

.artisan-nav {
  display: flex;
  gap: 3rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 400;
}

.artisan-nav a {
  color: var(--artisan-earth);
  text-decoration: none;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.artisan-nav a:hover { opacity: 1; }

.artisan-hero {
  min-height: 85vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.artisan-hero-left {
  padding: 4rem 5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--artisan-cream);
}

.artisan-kicker {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--artisan-clay);
  margin-bottom: 2rem;
}

.artisan-headline {
  font-family: 'Fraunces', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.25;
  color: var(--artisan-ink);
  margin-bottom: 1.5rem;
}

.artisan-headline em {
  font-style: italic;
  color: var(--artisan-amber);
}

.artisan-subtitle {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  color: var(--artisan-clay);
  max-width: 360px;
  line-height: 1.8;
  margin-bottom: 3rem;
}

.artisan-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  background: var(--artisan-earth);
  color: var(--artisan-cream);
  text-decoration: none;
  padding: 1rem 2rem;
  transition: all 0.3s;
  width: fit-content;
}

.artisan-btn:hover {
  background: var(--artisan-ink);
}

.artisan-btn svg { width: 1rem; }

.artisan-hero-right {
  position: relative;
  background: linear-gradient(135deg, var(--artisan-linen) 0%, var(--artisan-amber) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.artisan-circle-group {
  position: relative;
  width: 300px;
  height: 300px;
}

.artisan-organic-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  border: 2px solid;
  opacity: 0.25;
}

.artisan-organic-circle:nth-child(1) {
  width: 260px;
  height: 260px;
  margin-top: -130px;
  margin-left: -130px;
  border-color: var(--artisan-earth);
  border-radius: 50% 48% 52% 50% / 52% 50% 48% 52%;
}

.artisan-organic-circle:nth-child(2) {
  width: 180px;
  height: 180px;
  margin-top: -90px;
  margin-left: -90px;
  border-color: var(--artisan-amber);
  border-radius: 48% 52% 50% 50% / 50% 48% 52% 50%;
}

.artisan-organic-circle:nth-child(3) {
  width: 100px;
  height: 100px;
  margin-top: -50px;
  margin-left: -50px;
  border-color: var(--artisan-clay);
  border-radius: 52% 50% 48% 52% / 48% 52% 50% 48%;
  opacity: 0.35;
}

.artisan-dot {
  position: absolute;
  border-radius: 50%;
}

.artisan-dot:nth-child(4) {
  width: 8px;
  height: 8px;
  top: 15%;
  left: 20%;
  background: var(--artisan-amber);
  opacity: 0.4;
}

.artisan-dot:nth-child(5) {
  width: 6px;
  height: 6px;
  top: 70%;
  right: 25%;
  background: var(--artisan-clay);
  opacity: 0.5;
}

.artisan-dot:nth-child(6) {
  width: 10px;
  height: 10px;
  bottom: 20%;
  left: 30%;
  background: var(--artisan-warm);
  opacity: 0.35;
}

.artisan-dot:nth-child(7) {
  width: 5px;
  height: 5px;
  top: 25%;
  right: 15%;
  background: var(--artisan-earth);
  opacity: 0.3;
}

.artisan-dot:nth-child(8) {
  width: 7px;
  height: 7px;
  top: 45%;
  left: 10%;
  background: var(--artisan-sage);
  opacity: 0.3;
}

.artisan-activities {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.artisan-activity {
  position: relative;
  padding: 4rem;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  overflow: hidden;
}

.artisan-activity::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: transform 0.5s ease;
}

.artisan-activity:hover::before { transform: scale(1.02); }

.artisan-activity.gymnastics {
  background: linear-gradient(180deg, var(--artisan-cream) 0%, var(--artisan-linen) 100%);
}

.artisan-activity.gymnastics::before {
  background: radial-gradient(circle at 60% 30%, rgba(200,149,108,0.2) 0%, transparent 50%);
}

.artisan-activity.theatre {
  background: linear-gradient(180deg, var(--artisan-earth) 0%, #4A3328 100%);
}

.artisan-activity.theatre::before {
  background: radial-gradient(circle at 40% 70%, rgba(212,191,168,0.12) 0%, transparent 50%);
}

.artisan-activity-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.artisan-activity.gymnastics .artisan-activity-label { color: var(--artisan-clay); }
.artisan-activity.theatre .artisan-activity-label { color: rgba(255,255,255,0.5); }

.artisan-activity-title {
  font-family: 'Fraunces', serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: 1rem;
}

.artisan-activity.gymnastics .artisan-activity-title { color: var(--artisan-ink); }
.artisan-activity.theatre .artisan-activity-title { color: var(--artisan-cream); }

.artisan-activity-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 280px;
}

.artisan-activity.gymnastics .artisan-activity-desc { color: var(--artisan-clay); }
.artisan-activity.theatre .artisan-activity-desc { color: rgba(255,255,255,0.6); }

.artisan-activity-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}

.artisan-activity.gymnastics .artisan-activity-cta { color: var(--artisan-ink); }
.artisan-activity.theatre .artisan-activity-cta { color: var(--artisan-warm); }

.artisan-activity-cta svg {
  width: 1.25rem;
  transition: transform 0.3s;
}

.artisan-activity:hover .artisan-activity-cta svg { transform: translateX(6px); }

.artisan-intro {
  padding: 6rem 4rem;
  background: var(--artisan-cream);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: center;
  border-top: 1px solid var(--artisan-warm);
}

.artisan-intro-text {
  font-family: 'Fraunces', serif;
  font-size: 1.35rem;
  font-weight: 400;
  font-style: italic;
  color: var(--artisan-ink);
  line-height: 1.8;
}

.artisan-intro-links {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.artisan-intro-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--artisan-ink);
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--artisan-warm);
  transition: all 0.2s;
}

.artisan-intro-link:hover {
  color: var(--artisan-amber);
  padding-left: 0.5rem;
}

.artisan-intro-link svg { width: 1.25rem; }

.artisan-footer {
  padding: 2rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--artisan-cream);
  border-top: 1px solid var(--artisan-warm);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: var(--artisan-clay);
}

@media (max-width: 900px) {
  .artisan-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
  .artisan-nav { gap: 1.5rem; }
  .artisan-hero { grid-template-columns: 1fr; }
  .artisan-hero-left { padding: 5rem 1.5rem 3rem; }
  .artisan-hero-right { min-height: 40vh; }
  .artisan-circle-group { width: 220px; height: 220px; }
  .artisan-organic-circle:nth-child(1) { width: 200px; height: 200px; margin-top: -100px; margin-left: -100px; }
  .artisan-organic-circle:nth-child(2) { width: 140px; height: 140px; margin-top: -70px; margin-left: -70px; }
  .artisan-organic-circle:nth-child(3) { width: 80px; height: 80px; margin-top: -40px; margin-left: -40px; }
  .artisan-activities { grid-template-columns: 1fr; }
  .artisan-activity { padding: 3rem 1.5rem; }
  .artisan-intro { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 2rem; }
  .artisan-footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>

<div class="artisan-page">
  <header class="artisan-header">
    <div class="artisan-logo">Espace Bienestar</div>
    <nav class="artisan-nav">
<a href={base}>Accueil</a>
    <a href={`${base}activities`}>Activités</a>
    <a href={`${base}about`}>À propos</a>
    <a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <section class="artisan-hero">
    <div class="artisan-hero-left">
      <span class="artisan-kicker">Billère · Pau · France</span>
      <h1 class="artisan-headline">
        L'art du<br />
        <em>mouvement</em><br />
        authentique
      </h1>
      <p class="artisan-subtitle">{t.home.intro}</p>
      <a href={`${base}contact`} class="artisan-btn">
        Commencer le voyage
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="artisan-hero-right">
      <div class="artisan-circle-group">
        <div class="artisan-organic-circle"></div>
        <div class="artisan-organic-circle"></div>
        <div class="artisan-organic-circle"></div>
        <div class="artisan-dot"></div>
        <div class="artisan-dot"></div>
        <div class="artisan-dot"></div>
        <div class="artisan-dot"></div>
        <div class="artisan-dot"></div>
      </div>
    </div>
  </section>

  <section class="artisan-activities">
    <a href={activities[0].link} class="artisan-activity gymnastics">
      <span class="artisan-activity-label">{activities[0].subtitle}</span>
      <h2 class="artisan-activity-title">{activities[0].title}</h2>
      <p class="artisan-activity-desc">Le mouvement conscient comme l'argile façonnée avec soin et intention.</p>
      <span class="artisan-activity-cta">
        {activities[0].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="artisan-activity theatre">
      <span class="artisan-activity-label">{activities[1].subtitle}</span>
      <h2 class="artisan-activity-title">{activities[1].title}</h2>
      <p class="artisan-activity-desc">L'expression théâtrale comme l'artisanat de l'âme.</p>
      <span class="artisan-activity-cta">
        {activities[1].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>

  <section class="artisan-intro">
    <p class="artisan-intro-text">{t.home.hero.subtitle} — L'artisanat du bien-être, un chemin façonné avec patience.</p>
    <div class="artisan-intro-links">
      <a href={`${base}about`} class="artisan-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Rencontrer Sonia
      </a>
      <a href={`${base}schedule`} class="artisan-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Voir les horaires
      </a>
    </div>
  </section>

  <footer class="artisan-footer">
    <span>© 2026 Espace Bienestar</span>
    <span>Billère, France</span>
  </footer>
</div>
</ProposalLayout>
