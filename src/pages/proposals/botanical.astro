---
import ProposalLayout from '../../layouts/ProposalLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');
const base = import.meta.env.BASE_URL;

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: 'Mouvement conscient',
    link: `${base}activities/gymnastics`,
    cta: 'Découvrir'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: 'Expression créative',
    link: `${base}activities/theatre`,
    cta: 'Découvrir'
  }
];
---

<ProposalLayout title="Proposition - Botanique" styleName="08 · Botanique">
<style>
@import url('https://fonts.googleapis.com/css2?family=Petrona:ital,wght@0,400;0,500;0,600;1,400&family=Nunito:wght@300;400;500;600&display=swap');

:root {
  --botanic-green: #4A5D4A;
  --botanic-leaf: #6B8E6B;
  --botanic-sage: #9AAF9A;
  --botanic-cream: #F7F5F0;
  --botanic-earth: #8B7355;
  --botanic-petal: #D4A5A5;
  --botanic-mist: #E8EBE8;
}

html { scroll-behavior: smooth; }

.font-display { font-family: 'Petrona', serif; }
.font-body { font-family: 'Nunito', sans-serif; }

.botanic-page {
  min-height: 100vh;
  background: var(--botanic-cream);
  color: var(--botanic-green);
}

.botanic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 4rem;
  background: var(--botanic-cream);
  border-bottom: 1px solid var(--botanic-mist);
}

.botanic-logo {
  font-family: 'Petrona', serif;
  font-size: 1.3rem;
  font-weight: 500;
  letter-spacing: 0.03em;
  color: var(--botanic-green);
}

.botanic-nav {
  display: flex;
  gap: 3rem;
  font-family: 'Nunito', sans-serif;
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.botanic-nav a {
  color: var(--botanic-green);
  text-decoration: none;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.botanic-nav a:hover { opacity: 1; }

.botanic-hero {
  min-height: 85vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.botanic-hero-left {
  padding: 4rem 5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--botanic-cream);
  position: relative;
}

.botanic-kicker {
  font-family: 'Nunito', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--botanic-leaf);
  margin-bottom: 2rem;
}

.botanic-headline {
  font-family: 'Petrona', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 400;
  line-height: 1.25;
  color: var(--botanic-green);
  margin-bottom: 1.5rem;
}

.botanic-headline em {
  font-style: italic;
  color: var(--botanic-leaf);
}

.botanic-subtitle {
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  color: var(--botanic-sage);
  max-width: 360px;
  line-height: 1.8;
  margin-bottom: 3rem;
}

.botanic-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Nunito', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  background: var(--botanic-green);
  color: var(--botanic-cream);
  text-decoration: none;
  padding: 1rem 2rem;
  transition: all 0.3s;
  width: fit-content;
}

.botanic-btn:hover {
  background: var(--botanic-leaf);
}

.botanic-btn svg { width: 1rem; }

.botanic-hero-right {
  position: relative;
  background: linear-gradient(135deg, var(--botanic-mist) 0%, var(--botanic-sage) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.botanic-hero-right::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(74, 93, 74, 0.2) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(212, 165, 165, 0.15) 0%, transparent 35%);
}

.botanic-flower {
  position: relative;
  width: 220px;
  height: 220px;
}

.botanic-petal {
  position: absolute;
  width: 80px;
  height: 120px;
  background: var(--botanic-leaf);
  opacity: 0.3;
  border-radius: 50% 50% 50% 50% / 70% 70% 30% 30%;
}

.botanic-petal:nth-child(1) { top: 0; left: 50%; transform: translateX(-50%) rotate(0deg); }
.botanic-petal:nth-child(2) { top: 15%; right: 10%; transform: rotate(45deg); }
.botanic-petal:nth-child(3) { bottom: 15%; right: 10%; transform: rotate(90deg); }
.botanic-petal:nth-child(4) { bottom: 0; left: 50%; transform: translateX(-50%) rotate(180deg); }
.botanic-petal:nth-child(5) { bottom: 15%; left: 10%; transform: rotate(-90deg); }
.botanic-petal:nth-child(6) { top: 15%; left: 10%; transform: rotate(-45deg); }

.botanic-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 50px;
  height: 50px;
  background: var(--botanic-petal);
  border-radius: 50%;
  opacity: 0.7;
}

.botanic-activities {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.botanic-activity {
  position: relative;
  padding: 4rem;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  overflow: hidden;
}

.botanic-activity::before {
  content: '';
  position: absolute;
  inset: 0;
  transition: transform 0.5s ease;
}

.botanic-activity:hover::before { transform: scale(1.02); }

.botanic-activity.gymnastics {
  background: linear-gradient(180deg, var(--botanic-cream) 0%, var(--botanic-mist) 100%);
}

.botanic-activity.gymnastics::before {
  background: radial-gradient(circle at 60% 30%, rgba(107, 142, 107, 0.2) 0%, transparent 50%);
}

.botanic-activity.theatre {
  background: linear-gradient(180deg, var(--botanic-green) 0%, #2D3D2D 100%);
}

.botanic-activity.theatre::before {
  background: radial-gradient(circle at 40% 70%, rgba(212, 165, 165, 0.15) 0%, transparent 50%);
}

.botanic-activity-label {
  font-family: 'Nunito', sans-serif;
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.botanic-activity.gymnastics .botanic-activity-label { color: var(--botanic-leaf); }
.botanic-activity.theatre .botanic-activity-label { color: rgba(255,255,255,0.5); }

.botanic-activity-title {
  font-family: 'Petrona', serif;
  font-size: 2rem;
  font-weight: 400;
  margin-bottom: 1rem;
}

.botanic-activity.gymnastics .botanic-activity-title { color: var(--botanic-green); }
.botanic-activity.theatre .botanic-activity-title { color: var(--botanic-cream); }

.botanic-activity-desc {
  font-family: 'Nunito', sans-serif;
  font-size: 0.85rem;
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 280px;
}

.botanic-activity.gymnastics .botanic-activity-desc { color: var(--botanic-sage); }
.botanic-activity.theatre .botanic-activity-desc { color: rgba(255,255,255,0.6); }

.botanic-activity-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Nunito', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}

.botanic-activity.gymnastics .botanic-activity-cta { color: var(--botanic-green); }
.botanic-activity.theatre .botanic-activity-cta { color: var(--botanic-petal); }

.botanic-activity-cta svg {
  width: 1.25rem;
  transition: transform 0.3s;
}

.botanic-activity:hover .botanic-activity-cta svg { transform: translateX(6px); }

.botanic-intro {
  padding: 6rem 4rem;
  background: var(--botanic-cream);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: center;
  border-top: 1px solid var(--botanic-mist);
}

.botanic-intro-text {
  font-family: 'Petrona', serif;
  font-size: 1.35rem;
  font-weight: 400;
  font-style: italic;
  color: var(--botanic-green);
  line-height: 1.8;
}

.botanic-intro-links {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.botanic-intro-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: 'Nunito', sans-serif;
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--botanic-green);
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--botanic-mist);
  transition: all 0.2s;
}

.botanic-intro-link:hover {
  color: var(--botanic-leaf);
  padding-left: 0.5rem;
}

.botanic-intro-link svg { width: 1.25rem; }

.botanic-footer {
  padding: 2rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--botanic-cream);
  border-top: 1px solid var(--botanic-mist);
  font-family: 'Nunito', sans-serif;
  font-size: 0.75rem;
  color: var(--botanic-sage);
}

@media (max-width: 900px) {
  .botanic-header { padding: 1rem 1.5rem; flex-direction: column; gap: 1rem; }
  .botanic-nav { gap: 1.5rem; }
  .botanic-hero { grid-template-columns: 1fr; }
  .botanic-hero-left { padding: 5rem 1.5rem 3rem; }
  .botanic-hero-right { min-height: 40vh; }
  .botanic-flower { width: 160px; height: 160px; }
  .botanic-petal { width: 60px; height: 90px; }
  .botanic-activities { grid-template-columns: 1fr; }
  .botanic-activity { padding: 3rem 1.5rem; }
  .botanic-intro { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 2rem; }
  .botanic-footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>

<div class="botanic-page">
  <header class="botanic-header">
    <div class="botanic-logo">Espace Bienestar</div>
    <nav class="botanic-nav">
      <a href={base}>Accueil</a>
      <a href={`${base}activities`}>Activités</a>
      <a href={`${base}about`}>À propos</a>
      <a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <section class="botanic-hero">
    <div class="botanic-hero-left">
      <span class="botanic-kicker">Billère · Pau · France</span>
      <h1 class="botanic-headline">
        Grandir<br />
        <em>en</em><br />
        harmonie
      </h1>
      <p class="botanic-subtitle">{t.home.intro}</p>
      <a href={`${base}contact`} class="botanic-btn">
        Commencer
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="botanic-hero-right">
      <div class="botanic-flower">
        <div class="botanic-petal"></div>
        <div class="botanic-petal"></div>
        <div class="botanic-petal"></div>
        <div class="botanic-petal"></div>
        <div class="botanic-petal"></div>
        <div class="botanic-petal"></div>
        <div class="botanic-center"></div>
      </div>
    </div>
  </section>

  <section class="botanic-activities">
    <a href={activities[0].link} class="botanic-activity gymnastics">
      <span class="botanic-activity-label">{activities[0].subtitle}</span>
      <h2 class="botanic-activity-title">{activities[0].title}</h2>
      <p class="botanic-activity-desc">Le mouvement conscient comme la sève qui nourrit.</p>
      <span class="botanic-activity-cta">
        {activities[0].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>

    <a href={activities[1].link} class="botanic-activity theatre">
      <span class="botanic-activity-label">{activities[1].subtitle}</span>
      <h2 class="botanic-activity-title">{activities[1].title}</h2>
      <p class="botanic-activity-desc">L'expression créative comme une fleur qui s'ouvre.</p>
      <span class="botanic-activity-cta">
        {activities[1].cta}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </a>
  </section>

  <section class="botanic-intro">
    <p class="botanic-intro-text">{t.home.hero.subtitle} — La nature comme maître de bien-être.</p>
    <div class="botanic-intro-links">
      <a href={`${base}about`} class="botanic-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Rencontrer Sonia
      </a>
      <a href={`${base}schedule`} class="botanic-intro-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Voir les horaires
      </a>
    </div>
  </section>

  <footer class="botanic-footer">
    <span>© 2026 Espace Bienestar</span>
    <span>Billère, France</span>
  </footer>
</div>
</ProposalLayout>