---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t.contact.title}>
  <!-- Hero Section -->
  <section class="relative py-20 bg-hero-gradient overflow-hidden">
    <div class="hero-blob"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="animate-on-scroll">
        <p class="text-white/80 uppercase tracking-[0.2em] text-sm mb-4">{lang === 'fr' ? 'Rejoignez-nous' : 'Únase a nosotros'}</p>
        <h1 class="text-5xl md:text-6xl font-bold text-[var(--color-text)] mb-6">{t.contact.title}</h1>
        <p class="text-xl text-[var(--color-text)]/80 max-w-2xl">{t.contact.subtitle}</p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <!-- Info Card - Teal -->
      <div class="bg-[var(--color-secondary)] rounded-2xl p-8 text-white animate-on-scroll">
        <h2 class="text-2xl font-bold mb-6">{t.contact.location.title}</h2>

        <div class="space-y-6">
          <div class="flex gap-4">
            <svg class="w-6 h-6 text-[#D1E45B] mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <div>
              <p class="font-medium">{t.contact.location.address}</p>
              <p class="text-white/80">{t.contact.location.street}</p>
              <p class="text-white/80">{t.contact.location.city}</p>
            </div>
          </div>

          <div class="flex gap-4">
            <svg class="w-6 h-6 text-[#D1E45B] mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${t.contact.email}`} class="hover:text-[#D1E45B] transition-colors">
              {t.contact.email}
            </a>
          </div>

          <div class="flex gap-4">
            <svg class="w-6 h-6 text-[#D1E45B] mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href={`tel:${t.contact.phone.replace(/\s/g, '')}`} class="hover:text-[#D1E45B] transition-colors">
              {t.contact.phone}
            </a>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-white/20">
          <p class="text-sm text-white/70 mb-2">{lang === 'fr' ? 'Horaires' : 'Horarios'}</p>
          <p class="font-medium">{lang === 'fr' ? 'Lundi & Jeudi' : 'Lunes & Jueves'} 14h-16h</p>
          <p class="text-white/70 text-sm mt-1">{lang === 'fr' ? 'Stages: 1er dimanche du mois' : 'Talleres: 1er domingo del mes'}</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="card animate-on-scroll" style="transition-delay: 0.1s">
        <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-6">
          {lang === 'fr' ? 'Envoyez-nous un message' : 'Envíenos un mensaje'}
        </h2>

        <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-[var(--color-text)] mb-2">{t.contact.form.name}</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg border-2 border-[var(--color-violet-medium)] bg-white/50 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 outline-none transition-colors duration-200"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-[var(--color-text)] mb-2">{t.contact.form.email}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg border-2 border-[var(--color-violet-medium)] bg-white/50 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 outline-none transition-colors duration-200"
            />
          </div>

          <div>
            <label for="activity" class="block text-sm font-medium text-[var(--color-text)] mb-2">{t.contact.form.activity}</label>
            <select
              id="activity"
              name="activity"
              class="w-full px-4 py-3 rounded-lg border-2 border-[var(--color-violet-medium)] bg-white/50 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 outline-none transition-colors duration-200"
            >
              <option value="">{lang === 'fr' ? 'Sélectionnez une activité' : 'Seleccione una actividad'}</option>
              <option value="posturale">{t.activities.posturale.title}</option>
              <option value="rythmique">{t.activities.rythmique.title}</option>
              <option value="bienetre">{t.activities.bienetre.title}</option>
              <option value="amateur">{t.activities.amateur.title}</option>
              <option value="stages">{t.stages.title}</option>
              <option value="other">{lang === 'fr' ? 'Autre' : 'Otro'}</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-[var(--color-text)] mb-2">{t.contact.form.message}</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 rounded-lg border-2 border-[var(--color-violet-medium)] bg-white/50 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20 outline-none transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-pill w-full justify-center">
            {t.contact.form.submit}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>