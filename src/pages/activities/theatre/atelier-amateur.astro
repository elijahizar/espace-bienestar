---
import NordicLayout from '../../../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<NordicLayout title="Atelier de théâtre amateur – Sonia Cutri" pageLang={lang}>
  <section class="nordic-page-hero theatre">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">{t.activities.amateur.title}</span>
      <h1 class="nordic-page-headline">{lang === 'fr' ? 'Théâtre Amateur' : 'Teatro Amateur'}</h1>
    </div>
  </section>

  <section class="nordic-detail">
    <p class="nordic-section-text">
      {lang === 'fr'
        ? 'Atelier d\'initiation à la pratique théâtrale pour découvrir le travail de l\'acteur et votre potentiel créatif.'
        : 'Taller de iniciación a la práctica teatral para descubrir el trabajo del actor y su potencial creativo.'
      }
    </p>
    <p class="nordic-section-text">
      {lang === 'fr'
        ? 'Un espace ludique et expérimental où seront abordés l\'improvisation, la création de personnages, l\'interprétation des textes et la mise en scène.'
        : 'Un espacio lúdico y experimental donde se abordarán la improvisación, la creación de personajes, la interpretación de textos y la puesta en escena.'
      }
    </p>
    <p class="nordic-section-text">
      <em>{lang === 'fr' ? 'L\'atelier sera bouclé avec une représentation de fin d\'année.' : 'El taller se cerrará con una representación de fin de año.'}</em>
    </p>
  </section>

  <section class="nordic-cta theatre">
    <h2 class="nordic-cta-title">{lang === 'fr' ? 'Envie de jouer ?' : '¿Quieres actuar?'}</h2>
    <p class="nordic-cta-text">{lang === 'fr' ? 'Rejoignez notre atelier et explorez votre potentiel créatif.' : 'Únase a nuestro taller y explore su potencial creativo.'}</p>
    <a href={`${base}${lang === 'es' ? 'es/' : ''}contact`} class="nordic-btn">
      {t.nav.contact}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</NordicLayout>
