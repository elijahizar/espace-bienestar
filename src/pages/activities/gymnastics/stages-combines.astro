---
import NordicLayout from '../../../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const stages2026 = [
  { date: '18 Janvier', theme: lang === 'fr' ? 'Colonne Vertébrale' : 'Columna Vertebral' },
  { date: '15 Février', theme: lang === 'fr' ? 'Plexus Racine et Lombo-sacré' : 'Plexo Raíz y Lombo-sacro' },
  { date: '22 Mars', theme: lang === 'fr' ? 'Plexus Solaire et Cardiaque' : 'Plexo Solar y Cardíaco' },
  { date: '19 Avril', theme: lang === 'fr' ? 'Plexus Gorge et Front' : 'Plexo Garganta y Frente' },
  { date: '17 Mai', theme: lang === 'fr' ? 'Colonne Vertébrale' : 'Columna Vertebral' },
  { date: '14 Juin', theme: lang === 'fr' ? 'Plexus Racine et Lombo-sacré' : 'Plexo Raíz y Lombo-sacro' },
  { date: '5 Juillet', theme: lang === 'fr' ? 'Plexus Solaire et Cardiaque' : 'Plexo Solar y Cardíaco' }
];

const stageDetails = [
  {
    title: lang === 'fr' ? 'Stage Plexus Racine et Lombo-sacré' : 'Stage Plexo Raíz y Lombo-sacro',
    subtitle: lang === 'fr' ? '« Enracinement et Vitalité »' : '« Enraizamiento y Vitalidad »',
    description: lang === 'fr'
      ? 'Dans ce Stage on utilisera la musique du Centre Racine et Lombo-sacré pour mobiliser les zones de notre corps en liaison avec la Terre et l\'Eau, cherchant à activer notre ancrage et notre vitalité (l\'Eau de Vie). Nous travaillerons aussi différentes postures d\'étirements et de flexibilité en résonance avec ces Centres Énergétiques.'
      : 'En este Stage se utilizará la música del Centro Raíz y Lombo-sacro para movilizar las zonas de nuestro cuerpo en relación con la Tierra y el Agua, buscando activar nuestro anclaje y nuestra vitalidad (el Agua de Vida). Trabajaremos también diferentes posturas de estiramientos y flexibilidad en resonancia con estos Centros Energéticos.'
  },
  {
    title: lang === 'fr' ? 'Stage Plexus Solaire et Cardiaque' : 'Stage Plexo Solar y Cardíaco',
    subtitle: lang === 'fr' ? '« Les Portes du Vent et du Soleil »' : '« Las Puertas del Viento y del Sol »',
    description: lang === 'fr'
      ? 'Dans cet Stage on utilisera la musique du Centre Plexus Solaire et du Centre Cardiaque pour mobiliser les zones de notre corps en liaison avec le Feu et le Vent, cherchant à activer notre "Petit Sonar" et notre "Être en relation".'
      : 'En este Stage se utilizará la música del Centro Plexo Solar y del Centro Cardíaco para movilizar las zonas de nuestro cuerpo en relación con el Fuego y el Viento, buscando activar nuestro "Pequeño Sonar" y nuestro "Ser en relación".'
  },
  {
    title: lang === 'fr' ? 'Stage Plexus Gorge et Front' : 'Stage Plexo Garganta y Frente',
    subtitle: lang === 'fr' ? '« La Voix de la Sagesse »' : '« La Voz de la Sabiduría »',
    description: lang === 'fr'
      ? 'Dans ce Stage on utilisera la musique du Centre Gorge pour mobiliser les zones de notre corps en liaison avec l\'Espace Intérieur, cherchant à activer notre respiration pour purifier notre esprit.'
      : 'En este Stage se utilizará la música del Centro Garganta para movilizar las zonas de nuestro cuerpo en relación con el Espacio Interior, buscando activar nuestra respiración para purificar nuestra mente.'
  },
  {
    title: lang === 'fr' ? 'Stage Décompresser la Colonne Vertébrale' : 'Stage Descomprimir la Columna Vertebral',
    subtitle: lang === 'fr' ? '« Un besoin de liberté »' : '« Una necesidad de libertad »',
    description: lang === 'fr'
      ? 'La Colonne Vertébrale est notre Axe Centrale, on peut l\'appeler aussi le Pilier de la Vie qui relie les extrémités de notre corps et fonctionne comme un lien entre la Terre et le Ciel. Dans de nombreuses traditions spirituelles la Colonne Vertébrale est bien plus qu\'un axe physique, elle est un canal où circule l\'énergie terrestre liée à l\'ancrage, aux besoins matériels et à la sécurité et l\'énergie céleste, tournée vers la créativité, la spiritualité et l\'élévation.'
      : 'La Columna Vertebral es nuestro Eje Central, se puede llamar también el Pilar de la Vida que une los extremos de nuestro cuerpo y funciona como un vínculo entre la Tierra y el Cielo. En muchas tradiciones espirituales la Columna Vertebral es mucho más que un eje físico, es un canal donde circula la energía terrestre ligada al anclaje, a las necesidades materiales y a la seguridad y la energía celeste, orientada hacia la creatividad, la espiritualidad y la elevación.'
  }
];
---

<NordicLayout title="Stages Combinés – Sonia Cutri" pageLang={lang}>
  <section class="nordic-page-hero gymnastics">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">{t.stages.title}</span>
      <h1 class="nordic-page-headline">{lang === 'fr' ? 'Gymnastique Rythmique + Posturale' : 'Gimnasia Rítmica + Postural'}</h1>
      <p class="nordic-page-subtitle">
        {lang === 'fr' ? 'Un dimanche matin par mois, de 10h à 12h30' : 'Un domingo por la mañana al mes, de 10h a 12h30'}
      </p>
    </div>
  </section>

  <section class="nordic-detail">
    <h2 class="nordic-section-title">{lang === 'fr' ? 'Calendrier 2026' : 'Calendario 2026'}</h2>
    <table class="nordic-schedule">
      <thead>
        <tr>
          <th>{lang === 'fr' ? 'Date' : 'Fecha'}</th>
          <th>{lang === 'fr' ? 'Thème' : 'Tema'}</th>
        </tr>
      </thead>
      <tbody>
        {stages2026.map((stage) => (
          <tr>
            <td>{stage.date}</td>
            <td>{stage.theme}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <h2 class="nordic-section-title" style={{ marginTop: '3rem' }}>{lang === 'fr' ? 'Contenu des stages' : 'Contenido de los stages'}</h2>
    {stageDetails.map((stage) => (
      <div style={{ marginBottom: '2.5rem' }}>
        <h3 class="nordic-section-title" style={{ fontSize: '1.25rem', marginBottom: '0.5rem' }}>{stage.title}</h3>
        <p class="nordic-detail-quote" style={{ margin: '0 0 1rem' }}>{stage.subtitle}</p>
        <p class="nordic-section-text">{stage.description}</p>
        <p class="nordic-section-text">
          {lang === 'fr'
            ? 'Des accessoires comme balles, briques, ceintures et bolsters seront utilisés pour atteindre un état de conscience et de fluidité corporelle. On bouclera la séance avec la relaxation finale et une petite infusion.'
            : 'Accesorios como pelotas, ladrillos, cinturones y bolsters serán utilizados para alcanzar un estado de consciencia y fluidez corporal. Se cerrará la sesión con la relajación final y una pequeña infusión.'
          }
        </p>
      </div>
    ))}
  </section>

  <section class="nordic-cta gymnastics">
    <h2 class="nordic-cta-title">{lang === 'fr' ? 'Envie de participer ?' : '¿Quieres participar?'}</h2>
    <p class="nordic-cta-text">{lang === 'fr' ? 'Contactez-nous pour réserver votre place.' : 'Contáctenos para reservar su lugar.'}</p>
    <a href={`${base}${lang === 'es' ? 'es/' : ''}contact`} class="nordic-btn">
      {t.nav.contact}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</NordicLayout>
