---
import NordicLayout from '../../../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const subPages = [
  { title: t.activities.posturale.title, link: `${base}activities/gymnastics/posturale` },
  { title: t.activities.rythmique.title, link: `${base}activities/gymnastics/rythmique` },
  { title: t.stages.title, link: `${base}activities/gymnastics/stages-combines` }
];
---

<NordicLayout title={t.activities.gymnastics.title} pageLang={lang}>
  <section class="nordic-page-hero gymnastics">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">{lang === 'fr' ? 'Nos ateliers' : 'Nuestros talleres'}</span>
      <h1 class="nordic-page-headline">{t.activities.gymnastics.title}</h1>
      <p class="nordic-page-subtitle">{t.activities.gymnastics.description}</p>
    </div>
  </section>

  <section class="nordic-section">
    <div class="nordic-section-inner">
      <div class="nordic-nav-grid">
        {subPages.map((page) => (
          <a href={page.link} class="nordic-nav-card gymnastics">
            <span class="nordic-nav-card-title">{page.title}</span>
            <span class="nordic-nav-card-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="nordic-section">
    <div class="nordic-section-inner">
      <h2 class="nordic-section-title">Gymnastique Consciente</h2>
      <p class="nordic-section-text">Vitalité – Flexibilité – Tonicité – Souplesse – Détente</p>
      <p class="nordic-section-text">La Gymnastique Posturale ainsi que la Gymnastique Rythmique Expressive que je vous propose sont deux gymnastiques qui se pratiquent consciemment, en entendant la Conscience en tant qu’attention perceptive.</p>
      <p class="nordic-section-text">Ces deux gymnastiques tiennent compte de la relation étroite entre le corps et l'esprit et c’est pour cette raison que les deux modalités d’ateliers adaptés à vos préférences, vous propose une pratique corporelle qui stimulent les participants à mieux percevoir et comprendre leur corps comme une entité intégrée.</p>
      <p class="nordic-section-text">La pratique de différents exercices de tonicité, de flexibilité et de détente vous permettra de corriger vos mauvaises postures, d’élargir vos possibilités de mouvement et avoir une meilleure connaissance de vos ressources corporelles.</p>
      <p class="nordic-section-text">Avec la pratique régulière les tensions se relâchent, la flexibilité revient, les mouvements s’élargissent et vous retrouvez ainsi une meilleure tonicité et posture générale.</p>
      <p class="nordic-section-text">La pratique est accessible à tous et à toutes, sans limite d’âge.</p>

      <h2 class="nordic-section-title">La méthode</h2>
      <p class="nordic-section-text">Il s’agit de se reconnecter à son corps par le biais de nos sensations, en utilisant notre attention «Voir avec le corps»</p>
      <p class="nordic-section-text">Cette attention est guidée par l’enseignant; avec le temps, ce guidage s’intériorise et l’exploration devient aussi personnelle.</p>

      <h2 class="nordic-section-title">Métaphores inspirantes</h2>
      <p class="nordic-section-text">Les pieds comme racines, les jambes comme tronc, les hanches comme balance et source, les bras comme des ailes, les poumons comme fleur et plume, la poitrine comme ciel, le cœur comme soleil, les articulations comme élastiques, la souplesse comme des huiles, la détente musculaire comme de l’eau.</p>
      <p class="nordic-section-text"><em>Il s’agit sur tout d’Être-Là, car tous les moments sont ce moment.</em></p>
    </div>
  </section>





  <section class="nordic-cta gymnastics">
    <h2 class="nordic-cta-title">{lang === 'fr' ? 'Envie d\'essayer ?' : '¿Quieres probar?'}</h2>
    <p class="nordic-cta-text">{lang === 'fr' ? 'Rejoignez-nous pour une première séance découverte.' : 'Únase a nosotros para una primera sesión de descubrimiento.'}</p>
    <a href={`${base}${lang === 'es' ? 'es/' : ''}contact`} class="nordic-btn">
      {t.nav.contact}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</NordicLayout>
