---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const gymnasticsTypes = [
  {
    key: 'posturale',
    title: t.activities.posturale.title,
    schedule: t.activities.posturale.schedule,
    location: t.activities.posturale.location,
    description: t.activities.gymnastics.description,
    details: t.activities.posturale.details,
    icon: `<svg viewBox="0 0 64 64" fill="none" class="w-16 h-16">
      <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="2" stroke-opacity="0.3"/>
      <path d="M20 32C20 32 25 22 32 22C39 22 44 32 44 32" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M22 36C22 36 28 48 38 44C48 40 46 28 46 28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <circle cx="32" cy="32" r="5" fill="currentColor" fill-opacity="0.5"/>
      <path d="M32 24V18M32 46V52" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
    </svg>`
  },
  {
    key: 'rythmique',
    title: t.activities.rythmique.title,
    schedule: t.activities.rythmique.schedule,
    location: t.activities.rythmique.location,
    description: t.activities.rythmique.description,
    details: t.activities.rythmique.details,
    icon: `<svg viewBox="0 0 64 64" fill="none" class="w-16 h-16">
      <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="2" stroke-opacity="0.3"/>
      <path d="M18 28C18 28 24 20 32 20C40 20 46 28 46 28C46 28 40 36 32 36C24 36 18 28 18 28Z" stroke="currentColor" stroke-width="2"/>
      <path d="M22 38C22 38 28 50 40 44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <circle cx="32" cy="28" r="4" fill="currentColor"/>
      <path d="M26 44C26 44 32 48 38 44" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
    </svg>`
  }
];

const stagesInfo = {
  title: t.stages.title,
  subtitle: t.stages.subtitle,
  schedule: t.stages.schedule,
  location: t.stages.location,
  description: t.stages.description
};

const soniaCvGymnastics = {
  title: t.about.sonia.title,
  education: [
    lang === 'fr' ? '10 ans d\'expérience en éducation corporelle en Argentine' : '10 años de experiencia en educación corporal en Argentina',
    lang === 'fr' ? 'Yoga Iyengar, Hatha Yoga, Qi-Gong pratiqués' : 'Yoga Iyengar, Hatha Yoga, Qi-Gong practicados',
    lang === 'fr' ? 'Technique Alexander, Barre à Terre, Danse Théâtre' : 'Técnica Alexander, Barre à Terre, Danza Teatro',
    lang === 'fr' ? 'DU d\'Écologie Humaine, Université de Pau' : 'DU de Ecología Humana, Universidad de Pau'
  ],
  approach: lang === 'fr'
    ? 'Une synthèse personnelle issue de mon propre parcours, intégrant diverses approches corporelles pour un enseignement adapté à tous.'
    : 'Una síntesis personal de mi propio recorrido, integrando diversos enfoques corporales para una enseñanza adaptada a todos.'
};
---

<BaseLayout title={t.activities.gymnastics.title}>
  <!-- Hero Section -->
  <section class="relative py-20 bg-hero-gradient overflow-hidden">
    <div class="hero-blob"></div>
    <div class="hero-blob-teal"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="animate-on-scroll">
        <p class="text-white/80 uppercase tracking-[0.2em] text-sm mb-4">{lang === 'fr' ? 'Nos ateliers' : 'Nuestros talleres'}</p>
        <h1 class="text-5xl md:text-6xl font-bold text-[var(--color-primary)] mb-6">{t.activities.gymnastics.title}</h1>
        <p class="text-xl text-[var(--color-primary)]/80 max-w-2xl">{t.activities.gymnastics.description}</p>
      </div>
    </div>
  </section>

  <!-- Gymnastics Types -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto space-y-6">
      {gymnasticsTypes.map((type, index) => (
        <a href={`#${type.key}`} class="btn-block animate-on-scroll" style={`transition-delay: ${index * 0.1}s`}>
          <div class="btn-icon" set:html={type.icon}></div>
          <div class="btn-content">
            <h3 class="btn-title">{type.title}</h3>
            <p class="btn-meta">{type.schedule}</p>
          </div>
          <div class="btn-arrow">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}

      <!-- Stages Block -->
      <a href="#stages" class="btn-block animate-on-scroll" style="transition-delay: 0.2s">
        <div class="btn-icon">
          <svg viewBox="0 0 64 64" fill="none" class="w-10 h-10">
            <rect x="8" y="16" width="48" height="36" rx="4" stroke="currentColor" stroke-width="2"/>
            <path d="M8 24h48" stroke="currentColor" stroke-width="2"/>
            <path d="M20 8v12M44 8v12M8 12h48" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="24" cy="38" r="4" stroke="currentColor" stroke-width="2"/>
            <circle cx="40" cy="38" r="4" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <div class="btn-content">
          <h3 class="btn-title">{stagesInfo.title}</h3>
          <p class="btn-meta">{stagesInfo.subtitle} · {stagesInfo.schedule}</p>
        </div>
        <div class="btn-arrow">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Detailed Sections -->
  <section class="py-16 px-6 bg-[var(--color-background)]">
    <div class="max-w-5xl mx-auto space-y-20">
      {gymnasticsTypes.map((type, index) => (
        <div id={type.key} class="scroll-mt-24">
          <div class="grid md:grid-cols-2 gap-12 items-start">
            <div class="animate-on-scroll">
              <div class="inline-flex items-center gap-3 mb-6">
                <div class="text-[var(--color-accent)]" set:html={type.icon}></div>
                <h2 class="text-3xl font-bold text-[var(--color-primary)]">{type.title}</h2>
              </div>
              <p class="text-lg text-[var(--color-primary)]/80 mb-6 leading-relaxed">{type.description}</p>
              <p class="text-[var(--color-primary)]/70 mb-8">{type.details}</p>

              <div class="flex flex-wrap gap-4">
                <span class="btn-pill">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {type.schedule}
                </span>
              </div>
            </div>

            <div class="animate-on-scroll" style={`transition-delay: ${index * 0.2}s`}>
              <div class="bg-white rounded-2xl p-6 shadow-lg">
                <div class="flex items-center gap-3 mb-4">
                  <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                  <span class="font-medium text-[var(--color-primary)]">{lang === 'fr' ? 'Lieu' : 'Ubicación'}</span>
                </div>
                <p class="text-[var(--color-primary)]/70">{type.location}</p>
              </div>
            </div>
          </div>
        </div>
      ))}

      <!-- Stages Detailed -->
      <div id="stages" class="scroll-mt-24">
        <div class="text-center mb-10 animate-on-scroll">
          <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">{stagesInfo.title}</h2>
          <p class="text-lg text-[var(--color-primary)]/70">{stagesInfo.description}</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 animate-on-scroll">
          <div class="bg-[var(--color-primary)] rounded-2xl p-6 text-[var(--color-primary)] text-center">
            <svg class="w-12 h-12 mx-auto mb-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="font-semibold mb-2">{lang === 'fr' ? 'Horaires' : 'Horarios'}</p>
            <p class="text-[var(--color-primary)]/80">{stagesInfo.schedule}</p>
          </div>
          <div class="bg-[var(--color-secondary)] rounded-2xl p-6 text-white text-center">
            <svg class="w-12 h-12 mx-auto mb-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <p class="font-semibold mb-2">{lang === 'fr' ? 'Lieu' : 'Ubicación'}</p>
            <p class="text-white/80">{stagesInfo.location}</p>
          </div>
          <div class="bg-[var(--color-accent)] rounded-2xl p-6 text-white text-center">
            <svg class="w-12 h-12 mx-auto mb-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <p class="font-semibold mb-2">{lang === 'fr' ? 'Fréquence' : 'Frecuencia'}</p>
            <p class="text-white/80">{lang === 'fr' ? '1er dimanche du mois' : '1er domingo del mes'}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sonia CV Section -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="cv-section animate-on-scroll">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-16 h-16 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-3xl">
            👩‍🏫
          </div>
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-primary)]">{soniaCvGymnastics.title}</h2>
            <p class="text-[var(--color-primary)]/60">{lang === 'fr' ? 'Enseignante de gymnastique consciente' : 'Profesora de gimnasia consciente'}</p>
          </div>
        </div>

        <h3 class="text-xl font-semibold text-[var(--color-accent)] mb-4">{lang === 'fr' ? 'Formation & Parcours' : 'Formación y Trayectoria'}</h3>
        <div class="space-y-3 mb-8">
          {soniaCvGymnastics.education.map(item => (
            <div class="cv-item">
              <div class="cv-icon">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-[var(--color-primary)]">{item}</p>
            </div>
          ))}
        </div>

        <p class="text-[var(--color-primary)]/80 italic">"{soniaCvGymnastics.approach}"</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-[var(--color-primary)] py-16 px-6">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">{lang === 'fr' ? 'Envie d\'essayer ?' : '¿Quieres probar?'}</h2>
      <p class="text-[var(--color-primary)]/70 mb-8">{lang === 'fr' ? 'Rejoignez-nous pour une première séance découverte.' : 'Únase a nosotros para una primera sesión de descubrimiento.'}</p>
      <a href={lang === 'fr' ? '/contact' : '/es/contact'} class="btn-pill">
        {t.nav.contact}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>