---
import NordicLayout from '../../layouts/NordicLayout.astro';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const gymnasticsActivities = [
  {
    title: t.activities.posturale.title,
    label: lang === 'fr' ? 'Lundi 14h30' : 'Lunes 14h30',
    description: t.activities.posturale.cardDescription,
    link: `${base}${lang === 'es' ? 'es/' : ''}activities/gymnastics/posturale`
  },
  {
    title: t.activities.rythmique.title,
    label: lang === 'fr' ? 'Jeudi 14h' : 'Jueves 14h',
    description: t.activities.rythmique.cardDescription,
    link: `${base}${lang === 'es' ? 'es/' : ''}activities/gymnastics/rythmique`
  },
  {
    title: t.stages.title,
    label: lang === 'fr' ? 'Un dimanche/mes' : 'Un domingo/mes',
    description: t.stages.cardDescription,
    link: `${base}${lang === 'es' ? 'es/' : ''}activities/gymnastics/stages-combines`
  }
];

const theatreActivities = [
  {
    title: t.activities.bienetre.title,
    label: '',
    description: lang === 'fr'
      ? 'Atelier pour personnes souffrants de troubles d\'anxiété, phobie sociale, timidité excessive, burn-out.'
      : 'Taller para personas que sufren trastornos de ansiedad, fobia social, timidez excesiva, burn-out.',
    link: `${base}${lang === 'es' ? 'es/' : ''}activities/theatre/atelier-bien-etre`
  },
  {
    title: t.activities.amateur.title,
    label: '',
    description: lang === 'fr'
      ? 'Initiation à la pratique théâtrale : improvisation, création de personnages, interprétation.'
      : 'Iniciación a la práctica teatral: improvisación, creación de personajes, interpretación.',
    link: `${base}${lang === 'es' ? 'es/' : ''}activities/theatre/atelier-amateur`
  }
];
---

<NordicLayout title={t.nav.activities} pageLang={lang}>
  <section class="nordic-page-hero gymnastics">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">{lang === 'fr' ? 'Nos ateliers' : 'Nuestros talleres'}</span>
      <h1 class="nordic-page-headline">{t.activities.title}</h1>
      <p class="nordic-page-subtitle">{t.home.activities.subtitle}</p>
    </div>
  </section>

  <section class="nordic-activity-group gymnastics">
    <div class="nordic-activity-group-header">
      <div class="nordic-activity-group-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 16a1 1 0 1 1 1-1 1 1 0 0 1-1 1zm1-5h-2V7h2z"/>
        </svg>
      </div>
      <h2 class="nordic-activity-group-title">{lang === 'fr' ? 'Gymnastique Consciente' : 'Gimnasia Consciente'}</h2>
    </div>
    <div class="nordic-subcard-grid gymnastics">
      {gymnasticsActivities.map((activity) => (
        <a href={activity.link} class="nordic-subcard gymnastics">
          <span class="nordic-subcard-label">{activity.label}</span>
          <h3 class="nordic-subcard-title">{activity.title}</h3>
          <p class="nordic-subcard-desc">{activity.description}</p>
          <span class="nordic-subcard-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="nordic-activity-group theatre">
    <div class="nordic-activity-group-header">
      <div class="nordic-activity-group-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <h2 class="nordic-activity-group-title">{t.activities.theatre.title}</h2>
    </div>
    <div class="nordic-subcard-grid theatre">
      {theatreActivities.map((activity) => (
        <a href={activity.link} class="nordic-subcard theatre">
          <span class="nordic-subcard-label">{activity.label}</span>
          <h3 class="nordic-subcard-title">{activity.title}</h3>
          <p class="nordic-subcard-desc">{activity.description}</p>
          <span class="nordic-subcard-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="nordic-section nordic-section-alt">
    <div class="nordic-section-inner" style={{ textAlign: 'center' }}>
      <h2 class="nordic-section-title" style={{ textAlign: 'center' }}>{t.schedule.title}</h2>
      <p class="nordic-section-text" style={{ textAlign: 'center', maxWidth: '500px', margin: '0 auto 2rem' }}>{lang === 'fr' ? 'Consultez les horaires et dates des stages' : 'Consulte los horarios y fechas de los stages'}</p>
      <a href={`${base}${lang === 'es' ? 'es/' : ''}schedule`} class="nordic-btn" style={{ margin: '0 auto' }}>
        {lang === 'fr' ? 'Voir le calendrier' : 'Ver el calendario'}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </section>
</NordicLayout>