---
import NordicLayout from '../../../../layouts/NordicLayout.astro';
import { useTranslations } from '../../../../i18n/utils';

const t = useTranslations('es');
const base = import.meta.env.BASE_URL;

const subActivities = [
  {
    title: t.activities.bienetre.title,
    subtitle: t.activities.theatre.subtitle,
    description: t.activities.bienetre.description,
    link: `${base}es/activities/theatre/atelier-bien-etre`
  },
  {
    title: t.activities.amateur.title,
    subtitle: t.activities.theatre.subtitle,
    description: t.activities.amateur.description,
    link: `${base}es/activities/theatre/atelier-amateur`
  }
];
---

<NordicLayout title={t.activities.theatre.title} pageLang="es">
   <section class="nordic-page-hero theatre">
     <div class="nordic-page-hero-content">
       <span class="nordic-page-kicker">{t.activities.theatre.kicker}</span>
       <h1 class="nordic-page-headline">{t.activities.theatre.title}</h1>
       <p class="nordic-page-subtitle">{t.activities.theatre.subtitle}</p>
     </div>
   </section>

   <section class="nordic-activities">
     {subActivities.map((activity) => (
       <a href={activity.link} class="nordic-activity theatre">
         <span class="nordic-activity-label">{activity.subtitle}</span>
         <h2 class="nordic-activity-title">{activity.title}</h2>
         <p class="nordic-activity-desc">{activity.description}</p>
         <span class="nordic-activity-cta">
           {t.activities.explore}
           <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
         </span>
       </a>
     ))}
   </section>

   <section class="nordic-section">
     <div class="nordic-section-inner">
       <h2 class="nordic-section-title">{t.activities.theatre.introTitle}</h2>
       {t.activities.theatre.introParagraphs.map((paragraph) => (
         <p class="nordic-section-text">{paragraph}</p>
       ))}
       <p class="nordic-section-text"><strong>{t.activities.theatre.introClosing}</strong></p>
     </div>
   </section>

   <section class="nordic-cta theatre">
     <h2 class="nordic-cta-title">{t.activities.theatre.ctaTitle}</h2>
     <p class="nordic-cta-text">{t.activities.theatre.ctaText}</p>
    <a href={`${base}es/contact`} class="nordic-btn">
      {t.nav.contact}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</NordicLayout>
