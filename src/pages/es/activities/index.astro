---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const activities = [
  {
    key: 'gymnastics',
    title: t.activities.gymnastics.title,
    subtitle: lang === 'fr' ? 'Mouvement conscient' : 'Movimiento consciente',
    description: t.activities.gymnastics.description,
    link: lang === 'fr' ? '/activities/gymnastics' : '/es/activities/gymnastics',
    cta: lang === 'fr' ? 'Explorer' : 'Explorar',
    gradient: 'bg-activity-gymnastics'
  },
  {
    key: 'theatre',
    title: t.activities.theatre.title,
    subtitle: lang === 'fr' ? 'Expression créative' : 'Expresión creativa',
    description: t.activities.theatre.description,
    link: lang === 'fr' ? '/activities/theatre' : '/es/activities/theatre',
    cta: lang === 'fr' ? 'Explorer' : 'Explorar',
    gradient: 'bg-activity-theatre'
  }
];
---

<BaseLayout title={t.nav.activities}>
  <!-- Hero Section -->
  <section class="relative py-20 bg-hero-gradient overflow-hidden">
    <div class="hero-blob"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <div class="animate-on-scroll">
        <p class="text-white/80 uppercase tracking-[0.2em] text-sm mb-4">{lang === 'fr' ? 'Bienvenue' : 'Bienvenido'}</p>
        <h1 class="text-5xl md:text-6xl font-bold text-[var(--color-primary)] mb-6">{t.activities.title}</h1>
        <p class="text-xl text-[var(--color-primary)]/80 max-w-2xl">{t.home.activities.subtitle}</p>
      </div>
    </div>
  </section>

  <!-- Activities Grid -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      {activities.map((activity, index) => (
        <a
          href={activity.link}
          class={`relative group overflow-hidden ${activity.gradient} min-h-[400px] flex items-center justify-center animate-on-scroll`}
          style={`transition-delay: ${index * 0.1}s`}
        >
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/5 transition-all duration-500"></div>

          <div class="relative z-10 p-8 text-center">
            <p class="text-white/70 uppercase tracking-[0.2em] text-sm mb-3">{activity.subtitle}</p>
            <h2 class="text-4xl font-bold text-white mb-4">{activity.title}</h2>
            <p class="text-white/80 mb-6 max-w-sm mx-auto">{activity.description}</p>
            <span class="inline-flex items-center gap-2 text-white border border-white/50 px-6 py-3 rounded-full group-hover:bg-white group-hover:text-[#7C5CBF] transition-all duration-300">
              {activity.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Stages Overview -->
  <section class="py-16 px-6 bg-[var(--color-background)]">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll">
      <h2 class="text-3xl font-bold text-[var(--color-primary)] mb-4">{t.stages.title}</h2>
      <p class="text-lg text-[var(--color-primary)]/70 mb-8">{t.stages.description}</p>
      <a href={lang === 'fr' ? '/schedule' : '/es/schedule'} class="btn-pill">
        {lang === 'fr' ? 'Voir le calendrier' : 'Ver el calendario'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>