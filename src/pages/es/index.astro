---
import NordicLayout from '../../layouts/NordicLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
const base = import.meta.env.BASE_URL;
---

<NordicLayout title={t.home.hero.title} description={t.home.intro} pageLang="es">
  <section class="nordic-hero">
    <div class="nordic-hero-left">
      <span class="nordic-kicker">{t.activities.gymnastics.kicker}</span>
      <h1 class="nordic-headline">{t.home.hero.title}</h1>
      <p class="nordic-subtitle">{t.home.hero.subtitle}</p>
      <a href={`${base}es/activities`} class="nordic-btn">
        {t.activities.explore}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="nordic-hero-right">
      <div class="nordic-ring"></div>
      <div class="nordic-ring"></div>
      <div class="nordic-ring"></div>
      <div class="nordic-crystal-shape"></div>
      <div class="nordic-crystal-shape"></div>
      <div class="nordic-crystal-shape"></div>
    </div>
  </section>

  <section class="nordic-activities">
    <a href={`${base}es/activities/gymnastics`} class="nordic-activity gymnastics">
      <span class="nordic-activity-label">{t.activities.gymnastics.title}</span>
      <h2 class="nordic-activity-title">{t.activities.gymnastics.title}</h2>
      <p class="nordic-activity-desc">{t.activities.gymnastics.cardDescription}</p>
      <span class="nordic-activity-cta">
        {t.activities.explore}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>
    <a href={`${base}es/activities/theatre`} class="nordic-activity theatre">
      <span class="nordic-activity-label">{t.activities.theatre.title}</span>
      <h2 class="nordic-activity-title">{t.activities.theatre.title}</h2>
      <p class="nordic-activity-desc">{t.activities.theatre.cardDescription}</p>
      <span class="nordic-activity-cta">
        {t.activities.explore}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </a>
  </section>

  <section class="nordic-intro">
    <p class="nordic-intro-text">{t.home.intro}</p>
    <div class="nordic-intro-links">
      <a href={`${base}es/about`} class="nordic-intro-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        Sobre nosotros
      </a>
      <a href={`${base}es/schedule`} class="nordic-intro-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
        Horarios
      </a>
    </div>
  </section>
</NordicLayout>
