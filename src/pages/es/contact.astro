---
import NordicLayout from '../../layouts/NordicLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
const base = import.meta.env.BASE_URL;
---

<NordicLayout title={t.contact.title} description={t.contact.subtitle} pageLang="es">
  <section class="nordic-page-hero contact animate-on-scroll">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">{t.contact.kicker}</span>
      <h1 class="nordic-page-headline">{t.contact.title}</h1>
      <p class="nordic-page-subtitle">{t.contact.subtitle}</p>
    </div>
  </section>

  <section class="nordic-section animate-on-scroll" style="transition-delay: 0.1s">
    <div class="nordic-section-inner">
      <div class="nordic-info-grid">
        <div class="nordic-info-card frost">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          <span class="nordic-info-card-label">{t.contact.location.title}</span>
          <p class="nordic-info-card-value">
            {t.contact.location.address}<br/>
            {t.contact.location.street}<br/>
            {t.contact.location.city}
          </p>
        </div>
        <div class="nordic-info-card frost">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="nordic-info-card-label">{t.contact.emailLabel}</span>
          <a href={`mailto:${t.contact.email}`} class="nordic-info-card-value">{t.contact.email}</a>
        </div>
        <div class="nordic-info-card frost">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="nordic-info-card-label">{t.contact.phoneLabel}</span>
          <a href={`tel:${t.contact.phone.replace(/\s/g, '')}`} class="nordic-info-card-value">{t.contact.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="nordic-section nordic-section-alt animate-on-scroll" style="transition-delay: 0.2s">
    <div class="nordic-section-inner">
      <h2 class="nordic-section-title">{t.contact.form.title}</h2>

      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-[var(--nordic-shadow)] mb-2">
            {t.contact.form.name}
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border-2 border-[var(--nordic-ice)] bg-[var(--nordic-card)] focus:border-[var(--nordic-primary)] focus:ring-2 focus:ring-[var(--nordic-primary)]/20 outline-none transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-[var(--nordic-shadow)] mb-2">
            {t.contact.form.email}
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg border-2 border-[var(--nordic-ice)] bg-[var(--nordic-card)] focus:border-[var(--nordic-primary)] focus:ring-2 focus:ring-[var(--nordic-primary)]/20 outline-none transition-colors"
          />
        </div>

        <div>
          <label for="activity" class="block text-sm font-medium text-[var(--nordic-shadow)] mb-2">
            {t.contact.form.activity}
          </label>
          <select
            id="activity"
            name="activity"
            class="w-full px-4 py-3 rounded-lg border-2 border-[var(--nordic-ice)] bg-[var(--nordic-card)] focus:border-[var(--nordic-primary)] focus:ring-2 focus:ring-[var(--nordic-primary)]/20 outline-none transition-colors"
          >
            <option value="">{t.contact.form.activityPlaceholder}</option>
            <option value="posturale">{t.activities.posturale.title}</option>
            <option value="rythmique">{t.activities.rythmique.title}</option>
            <option value="bienetre">{t.activities.bienetre.title}</option>
            <option value="amateur">{t.activities.amateur.title}</option>
            <option value="stages">{t.stages.title}</option>
            <option value="other">{t.contact.form.other}</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-[var(--nordic-shadow)] mb-2">
            {t.contact.form.message}
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full px-4 py-3 rounded-lg border-2 border-[var(--nordic-ice)] bg-white focus:border-[var(--nordic-primary)] focus:ring-2 focus:ring-[var(--nordic-primary)]/20 outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <button type="submit" class="btn-pill">
          {t.contact.form.submit}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>
    </div>
  </section>
</NordicLayout>
