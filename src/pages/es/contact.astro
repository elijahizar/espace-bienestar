---
import NordicLayout from '../../layouts/NordicLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('es');
const base = import.meta.env.BASE_URL;
---

<NordicLayout title="Contacto" description="Contacte con Espace Bienestar para más información sobre nuestras actividades" pageLang="es">
  <section class="nordic-page-hero contact">
    <div class="nordic-page-hero-content">
      <span class="nordic-page-kicker">Contacto</span>
      <h1 class="nordic-page-headline">Contacte con nosotros</h1>
      <p class="nordic-page-subtitle">Estamos aquí para responder a sus preguntas</p>
    </div>
  </section>

  <section class="nordic-section">
    <div class="nordic-section-inner">
      <div class="nordic-info-grid">
        <div class="nordic-info-card gymnastics">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          <span class="nordic-info-card-label">Dirección</span>
          <p class="nordic-info-card-value">
            Salle du Sporting d'Este<br/>
            Avenue Saint John Perse<br/>
            Billère 64140
          </p>
        </div>
        <div class="nordic-info-card frost">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="nordic-info-card-label">Email</span>
          <a href="mailto:sonia.cutri@espace-bienestar.fr" class="nordic-info-card-value">sonia.cutri@espace-bienestar.fr</a>
        </div>
        <div class="nordic-info-card frost">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="nordic-info-card-label">Teléfono</span>
          <p class="nordic-info-card-value">+33 6 12 34 56 78</p>
        </div>
      </div>
    </div>
  </section>

  <section class="nordic-section nordic-section-alt">
    <div class="nordic-section-inner">
      <h2 class="nordic-section-title">Formulario de contacto</h2>
      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700">Nombre</label>
          <input type="text" id="name" name="name" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm p-3"/>
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input type="email" id="email" name="email" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm p-3"/>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm p-3"></textarea>
        </div>
        <div>
          <button type="submit" class="nordic-btn">
            Enviar mensaje
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>
</NordicLayout>
