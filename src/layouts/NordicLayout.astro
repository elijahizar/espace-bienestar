---
import '../styles/global.css';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  pageLang?: string;
}

const { title, description = "Espace Bienestar - Corps et Esprit en Harmonie. Gymnastique consciente et théâtre thérapeutique à Billère.", pageLang } = Astro.props;
const base = import.meta.env.BASE_URL;
const effectiveLang = pageLang ?? getLangFromUrl(Astro.url);
const langPrefix = effectiveLang === 'es' ? 'es/' : '';
const navBase = `${base}${langPrefix}`;
const t = useTranslations(effectiveLang);
---

<!DOCTYPE html>
<html lang={effectiveLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Espace Bienestar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
      html { scroll-behavior: smooth; }

      .nordic-page {
        min-height: 100vh;
        background: var(--nordic-white);
        color: var(--nordic-text);
      }

      .nordic-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 4rem;
        background: var(--nordic-white);
        border-bottom: 1px solid var(--nordic-ice);
      }

      .nordic-logo {
        font-family: 'Inter', sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--nordic-text);
      }

      .nordic-nav {
        display: flex;
        gap: 3rem;
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 400;
      }

      .nordic-nav a {
        color: var(--nordic-text);
        text-decoration: none;
        opacity: 0.6;
        transition: opacity 0.2s;
      }

      .nordic-nav a:hover { opacity: 1; }

      .nordic-hero {
        min-height: 40vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .nordic-hero-left {
        padding: 2rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--nordic-white);
      }

      .nordic-kicker {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--nordic-primary);
        margin-bottom: 2rem;
      }

      .nordic-headline {
        font-family: 'Inter', sans-serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 300;
        line-height: 1.25;
        color: var(--nordic-shadow);
        margin-bottom: 1.5rem;
      }

      .nordic-headline em { font-style: italic; font-weight: 300; color: var(--nordic-primary); }

      .nordic-subtitle {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 1rem;
        font-weight: 300;
        color: var(--nordic-text);
        opacity: 0.7;
        max-width: 360px;
        line-height: 1.8;
        margin-bottom: 3rem;
      }

      .nordic-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        background: var(--nordic-primary);
        color: var(--nordic-white);
        text-decoration: none;
        padding: 1rem 2rem;
        transition: all 0.3s;
        width: fit-content;
      }

      .nordic-btn:hover { background: var(--nordic-shadow); }
      .nordic-btn svg { width: 1rem; }

        .nordic-hero-right {
          position: relative;
          min-height: 40vh;
          background-color: var(--nordic-secondary);
          display: flex;
          align-items: center;
          justify-content: center;
          overflow: hidden;
          z-index: 1;
        }

       .nordic-hero-right::before {
         content: '';
         position: absolute;
         inset: 0;
         background: radial-gradient(circle at 40% 40%, rgba(155, 203, 147, 0.18), transparent 90%);
         pointer-events: none;
       }

       .nordic-hero-image {
         width: 100%;
         height: 100%;
         object-fit: cover;
         object-position: center;
         opacity: 0.6;
         filter: brightness(1.03) contrast(1.03) saturate(0.98);
         transition: filter 0.3s ease, opacity 0.3s ease;
       }
      .nordic-crystal-shape {
        position: absolute;
        border: 1px solid rgba(255,255,255,0.5);
        background: rgba(255,255,255,0.1);
      }
      .nordic-crystal-shape:nth-child(1) { width: 80px; height: 120px; top: 40px; left: 40px; transform: rotate(15deg); }
      .nordic-crystal-shape:nth-child(2) { width: 60px; height: 90px; top: 10px; left: 70px; transform: rotate(-10deg); border-color: rgba(255,255,255,0.3); }
      .nordic-crystal-shape:nth-child(3) { width: 50px; height: 80px; top: 80px; left: 20px; transform: rotate(25deg); border-color: rgba(255,255,255,0.4); background: rgba(167,199,231,0.1); }

      .nordic-ring { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 50%; border: 1px solid rgba(255,255,255,0.15); }
      .nordic-ring:nth-child(4) { width: 140px; height: 140px; }
      .nordic-ring:nth-child(5) { width: 200px; height: 200px; border-color: rgba(255,255,255,0.08); }
      .nordic-ring:nth-child(6) { width: 260px; height: 260px; border-color: rgba(255,255,255,0.05); }

      .nordic-activities { display: grid; grid-template-columns: repeat(2, 1fr); }
      .nordic-activities-3col { display: grid; grid-template-columns: repeat(3, 1fr); }
      .nordic-activities-3col .nordic-activity:nth-child(1) { background-color: var(--nordic-ice); }
      .nordic-activities-3col .nordic-activity:nth-child(2) { background-color: var(--nordic-primary); }
      .nordic-activities-3col .nordic-activity:nth-child(3) { background-color: #6B9B5B; color: var(--nordic-white); }
      .nordic-activities-3col .nordic-activity:nth-child(3) .nordic-activity-title { color: var(--nordic-white); }
      .nordic-activities-3col .nordic-activity:nth-child(3) .nordic-activity-desc { color: var(--nordic-white); opacity: 0.9; }
      .nordic-activities-3col .nordic-activity:nth-child(3) .nordic-activity-label { color: var(--nordic-white); opacity: 0.8; }
      .nordic-activities-3col .nordic-activity:nth-child(3) .nordic-activity-cta { color: var(--nordic-white); }
      @media (max-width: 900px) {
        .nordic-activities-3col { grid-template-columns: 1fr; }
        .nordic-activities-3col .nordic-activity { background-color: var(--nordic-primary); color: var(--nordic-text); }
        .nordic-activities-3col .nordic-activity .nordic-activity-title { color: var(--nordic-text); }
        .nordic-activities-3col .nordic-activity .nordic-activity-desc { color: var(--nordic-text); }
        .nordic-activities-3col .nordic-activity .nordic-activity-label { color: var(--nordic-text); opacity: 0.7; }
        .nordic-activities-3col .nordic-activity .nordic-activity-cta { color: var(--nordic-text); }
      }
      .nordic-activity {
        position: relative;
        padding: 4rem;
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        text-decoration: none;
        overflow: hidden;
      }
      .nordic-activity::before {
        content: '';
        position: absolute;
        inset: 0;
        transition: transform 0.5s ease;
      }
      .nordic-activity:hover::before { transform: scale(1.02); }
      .nordic-activity.gymnastics { background-color: var(--nordic-primary); }
      .nordic-activity.gymnastics::before { background: none; }
      .nordic-activity.theatre { background-color: var(--nordic-secondary); }
      .nordic-activity.theatre::before { background: none; }

      .nordic-activity-label {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
      }
      .nordic-activity.gymnastics .nordic-activity-label { color: var(--nordic-text); opacity: 0.7; }
      .nordic-activity.theatre .nordic-activity-label { color: var(--nordic-text); }

      .nordic-activity-title {
        color: black;
        font-family: 'Inter', sans-serif;
        font-size: 2rem;
        font-weight: 300;
        margin-bottom: 1rem;
      }
      .nordic-activity.gymnastics .nordic-activity-title { color: var(--nordic-text); }
      .nordic-activity.theatre .nordic-activity-title { color: var(--nordic-text); }

      .nordic-activity-desc {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 300;
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 480px;
      }
      .nordic-activity.gymnastics .nordic-activity-desc { color: var(--nordic-text); }
      .nordic-activity.theatre .nordic-activity-desc { color: var(--nordic-text); }

      .nordic-activity-cta { display: inline-flex; align-items: center; gap: 0.75rem; font-family: 'IBM Plex Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.05em; }
      .nordic-activity.gymnastics .nordic-activity-cta { color: var(--nordic-text); }
      .nordic-activity.theatre .nordic-activity-cta { color: var(--nordic-text); }
      .nordic-activity-cta svg { width: 1.25rem; transition: transform 0.3s; }
      .nordic-activity:hover .nordic-activity-cta svg { transform: translateX(6px); }

      .nordic-activity-group { padding: 4rem 5rem; }
      .nordic-activity-group.gymnastics { background: var(--nordic-ice); }
      .nordic-activity-group.theatre { background: var(--nordic-frost); }

      .nordic-activity-group-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
      .nordic-activity-group-icon { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .nordic-activity-group.gymnastics .nordic-activity-group-icon { background: var(--nordic-primary); color: white; }
      .nordic-activity-group.theatre .nordic-activity-group-icon { background: var(--nordic-secondary); color: white; }
      .nordic-activity-group-title { font-size: 1.25rem; font-weight: 400; color: var(--nordic-shadow); }

      .nordic-subcard-grid { display: grid; gap: 1.5rem; }
      .nordic-subcard-grid.gymnastics { grid-template-columns: repeat(3, 1fr); }
      .nordic-subcard-grid.theatre { grid-template-columns: repeat(2, 1fr); }

      .nordic-subcard { display: flex; flex-direction: column; padding: 2rem; min-height: 260px; text-decoration: none; transition: all 0.3s ease; border-radius: 2px; }
      .nordic-subcard:hover { transform: translateY(-4px); }
      .nordic-subcard.gymnastics { background: var(--nordic-white); border-left: 3px solid var(--nordic-primary); box-shadow: 0 2px 8px rgba(44,62,80,0.08); }
      .nordic-subcard.theatre { background: var(--nordic-white); border-left: 3px solid var(--nordic-secondary); box-shadow: 0 2px 8px rgba(44,62,80,0.08); }

      .nordic-subcard-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.6; margin-bottom: 0.5rem; }
      .nordic-subcard-title { font-family: 'Inter', sans-serif; font-size: 1.25rem; font-weight: 400; color: var(--nordic-shadow); margin-bottom: 0.75rem; }
      .nordic-subcard-desc { font-family: 'IBM Plex Sans', sans-serif; font-size: 0.85rem; font-weight: 300; color: var(--nordic-text); line-height: 1.6; flex-grow: 1; }
      .nordic-subcard-arrow { margin-top: 1rem; color: var(--nordic-shadow); opacity: 0.4; transition: all 0.3s; }
      .nordic-subcard:hover .nordic-subcard-arrow { opacity: 1; transform: translateX(4px); }

      @media (max-width: 900px) {
        .nordic-subcard-grid.gymnastics { grid-template-columns: repeat(2, 1fr); }
        .nordic-subcard-grid.theatre { grid-template-columns: repeat(2, 1fr); }
      }

      @media (max-width: 600px) {
        .nordic-subcard-grid.gymnastics { grid-template-columns: 1fr; }
        .nordic-subcard-grid.theatre { grid-template-columns: 1fr; }
        .nordic-activity-group { padding: 3rem 1.5rem; }
      }

      .nordic-intro {
        padding: 6rem 4rem;
        background: var(--nordic-mist);
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 4rem;
        align-items: center;
        border-top: 1px solid var(--nordic-ice);
      }
      .nordic-intro-text {
        font-family: 'Inter', sans-serif;
        font-size: 1.35rem;
        font-weight: 300;
        font-style: italic;
        color: var(--nordic-shadow);
        line-height: 1.8;
      }
      .nordic-intro-links { display: flex; flex-direction: column; gap: 1rem; }
      .nordic-intro-link {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 400;
        color: var(--nordic-text);
        text-decoration: none;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--nordic-ice);
        transition: all 0.2s;
      }
      .nordic-intro-link:hover { color: var(--nordic-primary); padding-left: 0.5rem; }
      .nordic-intro-link svg { width: 1.25rem; }

      /* Page Hero (for detail pages) */
      .nordic-page-hero {
        min-height: 50vh;
        display: flex;
        align-items: center;
        padding: 4rem 5rem;
        position: relative;
        overflow: hidden;
      }
      .nordic-page-hero.gymnastics { background-color: var(--nordic-mist); border-left: 4px solid var(--nordic-primary); }
      .nordic-page-hero.theatre { background-color: var(--nordic-mist); border-left: 4px solid var(--nordic-secondary); }
      .nordic-page-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: none;
      }
      .nordic-page-hero-content { position: relative; z-index: 1; max-width: 600px; }
      .nordic-page-kicker {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        display: block;
      }
      .nordic-page-hero.gymnastics .nordic-page-kicker { color: var(--nordic-text); opacity: 0.7; }
      .nordic-page-hero.theatre .nordic-page-kicker { color: var(--nordic-text); opacity: 0.7; }
      .nordic-page-headline {
        font-family: 'Inter', sans-serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 300;
        line-height: 1.25;
        margin-bottom: 1rem;
      }
      .nordic-page-hero.gymnastics .nordic-page-headline { color: var(--nordic-shadow); }
      .nordic-page-hero.theatre .nordic-page-headline { color: var(--nordic-shadow);}
      .nordic-page-subtitle {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        max-width: 480px;
      }
      .nordic-page-hero.gymnastics .nordic-page-subtitle { color: var(--nordic-text); }
      .nordic-page-hero.theatre .nordic-page-subtitle { color: var(--nordic-text); }

      /* Content Sections */
      .nordic-section { padding: 4rem 5rem; }
      .nordic-section-alt { background: var(--nordic-mist); }
      .nordic-section-inner { max-width: 900px; margin: 0 auto; }
      .nordic-section-title {
        font-family: 'Inter', sans-serif;
        font-size: 1.5rem;
        font-weight: 400;
        color: var(--nordic-shadow);
        margin-bottom: 1.5rem;
      }
      .nordic-section-text {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 300;
        line-height: 1.8;
        color: var(--nordic-text);
        margin-bottom: 1rem;
      }
      .nordic-section-text em { font-style: italic; color: var(--nordic-primary); }
      .nordic-section-text strong { font-weight: 500; color: var(--nordic-shadow); }

      /* Nav Cards Grid */
      .nordic-nav-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .nordic-nav-card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2rem 2.5rem;
        text-decoration: none;
        transition: transform 0.3s ease;
        overflow: hidden;
      }
      .nordic-nav-card:hover { transform: translateY(-2px); }
      .nordic-nav-card.gymnastics { background-color: var(--nordic-primary); }
      .nordic-nav-card.theatre { background-color: var(--nordic-secondary); }
      .nordic-nav-card-title {
        font-family: 'Inter', sans-serif;
        font-size: 1.25rem;
        font-weight: 400;
      }
      .nordic-nav-card.gymnastics .nordic-nav-card-title { color: var(--nordic-shadow); }
      .nordic-nav-card.theatre .nordic-nav-card-title { color: var(--nordic-white); }
      .nordic-nav-card-arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s;
      }
      .nordic-nav-card.gymnastics .nordic-nav-card-arrow { color: var(--nordic-shadow); }
      .nordic-nav-card.theatre .nordic-nav-card-arrow { color: var(--nordic-white); }
      .nordic-nav-card:hover .nordic-nav-card-arrow { transform: translateX(4px); }
      .nordic-nav-card-arrow svg { width: 1.25rem; height: 1.25rem; }

      /* Detail Content */
      .nordic-detail {
        padding: 4rem 5rem;
        max-width: 900px;
        margin: 0 auto;
      }
      .nordic-detail-quote {
        font-family: 'Inter', sans-serif;
        font-size: 1.25rem;
        font-weight: 300;
        font-style: italic;
        color: var(--nordic-primary);
        border-left: 3px solid var(--nordic-primary);
        padding-left: 1.5rem;
        margin: 2rem 0;
      }
      .nordic-detail-meta {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 400;
        color: var(--nordic-text);
        opacity: 0.7;
        margin-bottom: 2rem;
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .nordic-detail-meta span { display: flex; align-items: center; gap: 0.5rem; }
      .nordic-detail-meta svg { width: 1rem; height: 1rem; }

      /* Info Cards */
      .nordic-info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      .nordic-info-card {
        padding: 2rem;
        text-align: center;
      }
      .nordic-info-card.gymnastics { background: var(--nordic-ice); }
      .nordic-info-card.theatre { background: var(--nordic-violet); color: var(--nordic-white); }
      .nordic-info-card.frost { background: var(--nordic-frost); }
      .nordic-info-card svg { width: 2rem; height: 2rem; margin-bottom: 1rem; }
      .nordic-info-card.gymnastics svg { color: var(--nordic-shadow); }
      .nordic-info-card.theatre svg { color: var(--nordic-white); }
      .nordic-info-card.frost svg { color: var(--nordic-shadow); }
      .nordic-info-card-label {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        opacity: 0.7;
      }
      .nordic-info-card-value {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 400;
      }

      /* Schedule Table */
      .nordic-schedule {
        width: 100%;
        border-collapse: collapse;
        font-family: 'IBM Plex Sans', sans-serif;
      }
      .nordic-schedule th {
        text-align: left;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--nordic-text);
        opacity: 0.5;
        padding: 1rem 0;
        border-bottom: 1px solid var(--nordic-ice);
      }
      .nordic-schedule td {
        padding: 1rem 0;
        font-size: 0.95rem;
        font-weight: 300;
        border-bottom: 1px solid var(--nordic-ice);
        color: var(--nordic-text);
      }
      .nordic-schedule tr:last-child td { border-bottom: none; }

      /* CTA Section */
      .nordic-cta {
        padding: 4rem 5rem;
        text-align: center;
      }
      .nordic-cta.gymnastics { background-color: var(--nordic-primary); }
      .nordic-cta.theatre { background-color: var(--nordic-secondary); }
      .nordic-cta-title {
        font-family: 'Inter', sans-serif;
        font-size: 1.75rem;
        font-weight: 300;
        margin-bottom: 1rem;
      }
      .nordic-cta.gymnastics .nordic-cta-title { color: var(--nordic-shadow); }
      .nordic-cta.theatre .nordic-cta-title { color: var(--nordic-white); }
      .nordic-cta-text {
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 300;
        margin-bottom: 2rem;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
      }
      .nordic-cta.gymnastics .nordic-cta-text { color: var(--nordic-text); opacity: 0.7; }
      .nordic-cta.theatre .nordic-cta-text { color: rgba(255,255,255,0.7); }

      /* Responsive */
      @media (max-width: 900px) {
        .nordic-page-hero { padding: 3rem 1.5rem; min-height: 40vh; }
        .nordic-section { padding: 3rem 1.5rem; }
        .nordic-detail { padding: 3rem 1.5rem; }
        .nordic-nav-grid { grid-template-columns: 1fr; }
        .nordic-info-grid { grid-template-columns: 1fr; }
        .nordic-cta { padding: 3rem 1.5rem; }
        .nordic-detail-meta { flex-direction: column; gap: 0.75rem; }
      }

      .nordic-footer {
        padding: 3rem 4rem;
        background: var(--nordic-white);
        border-top: 1px solid var(--nordic-ice);
        font-family: 'IBM Plex Sans', sans-serif;
      }

      .nordic-footer-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }

      .nordic-footer-section h4 {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--nordic-shadow);
        margin-bottom: 0.75rem;
      }

      .nordic-footer-section p,
      .nordic-footer-section li {
        font-size: 0.8rem;
        color: var(--nordic-text);
        opacity: 0.7;
        line-height: 1.6;
      }

      .nordic-footer-section ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .nordic-footer-section li {
        margin-bottom: 0.5rem;
      }

      .nordic-footer-section a {
        color: var(--nordic-text);
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.2s;
      }

      .nordic-footer-section a:hover {
        opacity: 1;
        color: var(--nordic-primary);
      }

      .nordic-footer-bottom {
        padding-top: 1.5rem;
        border-top: 1px solid var(--nordic-ice);
        text-align: center;
        font-size: 0.75rem;
        color: var(--nordic-text);
        opacity: 0.5;
      }

      .nordic-footer-icon {
        width: 1rem;
        height: 1rem;
        display: inline-block;
        vertical-align: middle;
        margin-right: 0.25rem;
      }

      /* Language Switcher */
      .nordic-lang-switch {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.08em;
      }

      .nordic-lang-switch a {
        color: var(--nordic-text);
        text-decoration: none;
        opacity: 0.5;
        transition: opacity 0.2s;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }

      .nordic-lang-switch a:hover { opacity: 1; }
      .nordic-lang-switch a.active {
        opacity: 1;
        background: var(--nordic-ice);
        color: var(--nordic-primary);
      }

      .nordic-lang-divider {
        color: var(--nordic-text);
        opacity: 0.3;
      }

      /* Mobile Toggle */
      .nordic-mobile-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        color: var(--nordic-text);
      }

      .nordic-mobile-toggle svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      /* Mobile Menu */
      .nordic-mobile-menu {
        display: none;
        position: fixed;
        inset: 0;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--nordic-white);
        z-index: 1000;
        padding: 6rem 2rem 2rem;
        flex-direction: column;
        gap: 2rem;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
      }

      .nordic-mobile-menu.open {
        display: flex;
        opacity: 1;
        visibility: visible;
      }

      .nordic-mobile-menu .close-btn {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--nordic-text);
        padding: 0.5rem;
      }

      .nordic-mobile-menu .close-btn svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      .nordic-mobile-menu nav {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .nordic-mobile-menu nav a {
        font-family: 'Inter', sans-serif;
        font-size: 1.5rem;
        font-weight: 300;
        color: var(--nordic-text);
        text-decoration: none;
        transition: color 0.2s;
      }

      .nordic-mobile-menu nav a:hover { color: var(--nordic-primary); }

      .nordic-mobile-menu .mobile-lang-switch {
        margin-top: auto;
        display: flex;
        gap: 1rem;
        font-family: 'IBM Plex Sans', sans-serif;
        font-size: 0.9rem;
      }

      .nordic-mobile-menu .mobile-lang-switch a {
        font-size: 0.9rem;
        opacity: 0.5;
        transition: opacity 0.2s;
      }

      .nordic-mobile-menu .mobile-lang-switch a.active,
      .nordic-mobile-menu .mobile-lang-switch a:hover { opacity: 1; }

      @media (max-width: 900px) {
        .nordic-header { padding: 1rem 1.5rem; flex-direction: row; justify-content: space-between; }
        .nordic-nav { display: none; }
        .nordic-lang-switch { display: none; }
        .nordic-mobile-toggle { display: block; }
        .nordic-hero { grid-template-columns: 1fr; }
        .nordic-hero-left { padding: 5rem 1.5rem 3rem; }
        .nordic-hero-right { min-height: 40vh; }
        .nordic-activities { grid-template-columns: 1fr; }
        .nordic-activity { padding: 3rem 1.5rem; }
        .nordic-intro { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 2rem; }
        .nordic-footer { padding: 2rem 1.5rem; }
        .nordic-footer-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .nordic-footer-bottom { flex-direction: column; gap: 0.5rem; }
      }

    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--nordic-white)]">
    <a href="#main-content" class="skip-link">{t.nav.skipLink}</a>
    <div class="nordic-page">
      <header class="nordic-header">
        <div class="nordic-logo"><a href={navBase}>Espace bienestar</a></div>
         <div class="nordic-lang-switch">
           <a href={base} class={effectiveLang !== 'es' ? 'active' : ''}>FR</a>
           <span class="nordic-lang-divider">·</span>
           <a href={`${base}es/`} class={effectiveLang === 'es' ? 'active' : ''}>ES</a>
         </div>
        <nav class="nordic-nav">
<a href={navBase}>{t.nav.home}</a>
<a href={`${navBase}activities`}>{t.nav.activities}</a>
<a href={`${navBase}about`}>{t.nav.about}</a>
<a href={`${navBase}contact`}>{t.nav.contact}</a>
        </nav>
        <button class="nordic-mobile-toggle" id="mobile-menu-toggle" aria-label="Menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </header>
      <main id="main-content" class="flex-1">
        <slot />
      </main>
      <footer class="nordic-footer">
        <div class="nordic-footer-grid">
          <div class="nordic-footer-section">
            <h4>Espace Bienestar</h4>
            <p>{t.footer.tagline}</p>
            <p style="margin-top: 0.75rem;">
              <svg class="nordic-footer-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              Salle du Sporting d'Este<br/>
              Avenue Saint John Perse<br/>
              Billère 64140
            </p>
          </div>
          <div class="nordic-footer-section">
            <h4>Navigation</h4>
            <ul>
              <li><a href={navBase}>{t.nav.home}</a></li>
              <li><a href={`${navBase}activities`}>{t.nav.activities}</a></li>
              <li><a href={`${navBase}about`}>{t.nav.about}</a></li>
              <li><a href={`${navBase}schedule`}>{t.nav.schedule}</a></li>
              <li><a href={`${navBase}contact`}>{t.nav.contact}</a></li>
            </ul>
          </div>
          <div class="nordic-footer-section">
            <h4>Contact</h4>
            <ul>
              <li>
                <a href={`mailto:${t.contact.email}`}>
                  <svg class="nordic-footer-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  {t.contact.email}
                </a>
              </li>
              <li>
                <svg class="nordic-footer-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {t.contact.phone}
              </li>
            </ul>
          </div>
        </div>
        <div class="nordic-footer-bottom">
          {t.footer.copyright}
        </div>
      </footer>
    </div>
  <script>
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const closeBtn = document.getElementById('mobile-menu-close');

      if (mobileToggle && mobileMenu && closeBtn) {
        mobileToggle.addEventListener('click', () => {
          mobileMenu.classList.add('open');
          document.body.style.overflow = 'hidden';
        });

        closeBtn.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          document.body.style.overflow = '';
        });

        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = '';
          });
        });
      }
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver(
          entries => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.15 }
        );
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
      });
    </script>
    <div class="nordic-mobile-menu" id="mobile-menu">
      <button class="close-btn" id="mobile-menu-close" aria-label="Fermer">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <nav>
        <a href={navBase}>Accueil</a>
        <a href={`${navBase}activities`}>Activités</a>
        <a href={`${navBase}about`}>À propos</a>
        <a href={`${navBase}schedule`}>Horaires</a>
        <a href={`${navBase}contact`}>Contact</a>
      </nav>
       <div class="mobile-lang-switch">
         <a href={base} class={effectiveLang !== 'es' ? 'active' : ''}>FR</a>
         <span>·</span>
         <a href={`${base}es/`} class={effectiveLang === 'es' ? 'active' : ''}>ES</a>
       </div>
    </div>
  </body>
</html>
