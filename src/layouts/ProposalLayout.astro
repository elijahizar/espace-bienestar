---
interface Props {
  title: string;
  styleName?: string;
}

const { title, styleName } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Espace Bienestar</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    main { flex: 1; }

    .proposal-nav {
      background: #1A1A1A;
      padding: 0.75rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .proposal-nav-back {
      color: white;
      text-decoration: none;
      font-family: system-ui, sans-serif;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: opacity 0.2s;
      cursor: pointer;
    }

    .proposal-nav-back:hover { opacity: 0.7; }

    .proposal-nav-back svg { width: 16px; height: 16px; }

    .proposal-nav-label {
      font-family: system-ui, sans-serif;
      font-size: 0.7rem;
      color: #767676;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <nav class="proposal-nav">
    <a href={`${base}proposals/`} class="proposal-nav-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Retour aux propositions
    </a>
    {styleName && <span class="proposal-nav-label">{styleName}</span>}
  </nav>
  <main>
    <slot />
  </main>
</body>
</html>
