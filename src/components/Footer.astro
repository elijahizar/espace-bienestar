---
import { useTranslations, getLangFromUrl, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-[var(--color-accent-dark)] text-white py-12 mt-16">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="font-heading text-lg font-semibold mb-4">Espace Bienestar</h3>
        <p class="text-sm opacity-80 leading-relaxed">
          {t.footer.tagline}
        </p>
        <p class="text-sm opacity-60 mt-2">
          <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          {t.contact.location.address}<br/>
          {t.contact.location.street}<br/>
          {t.contact.location.city}
        </p>
      </div>

      <div>
        <h3 class="font-heading text-lg font-semibold mb-4">
          {t.footer.navigation}
        </h3>
        <ul class="space-y-2 text-sm opacity-80">
          <li><a href={localizePath('', lang)} class="hover:opacity-100 transition-opacity">{t.nav.home}</a></li>
          <li><a href={localizePath('activities', lang)} class="hover:opacity-100 transition-opacity">{t.nav.activities}</a></li>
          <li><a href={localizePath('about', lang)} class="hover:opacity-100 transition-opacity">{t.nav.about}</a></li>
          <li><a href={localizePath('schedule', lang)} class="hover:opacity-100 transition-opacity">{t.nav.schedule}</a></li>
          <li><a href={localizePath('contact', lang)} class="hover:opacity-100 transition-opacity">{t.nav.contact}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-lg font-semibold mb-4">
          {t.footer.contact}
        </h3>
        <ul class="space-y-2 text-sm opacity-80">
          <li>
            <a href={`mailto:${t.contact.email}`} class="hover:opacity-100 transition-opacity flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {t.contact.email}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {t.contact.phone}
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/20 pt-6 text-center">
      <p class="text-sm opacity-60">{t.footer.copyright}</p>
    </div>
  </div>
</footer>