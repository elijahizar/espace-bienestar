---
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const navItems = [
  { key: 'home', href: lang === 'fr' ? `${base}` : `${base}es` },
  { key: 'activities', href: lang === 'fr' ? `${base}activities` : `${base}es/activities` },
  { key: 'about', href: lang === 'fr' ? `${base}about` : `${base}es/about` },
  { key: 'schedule', href: lang === 'fr' ? `${base}schedule` : `${base}es/schedule` },
  { key: 'contact', href: lang === 'fr' ? `${base}contact` : `${base}es/contact` },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => currentPath === href || currentPath === href + '/';
---

<nav class="bg-[var(--color-primary)] sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <a href={lang === 'fr' ? base : `${base}es`} class="flex items-center gap-3 group">
        <svg class="w-10 h-10 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 40 40" fill="none">
          <circle cx="20" cy="20" r="18" stroke="white" stroke-width="2"/>
          <path d="M20 8C20 8 12 16 12 22C12 28 20 32 20 32C20 32 28 28 28 22C28 16 20 8 20 8Z" fill="white" opacity="0.3"/>
          <circle cx="20" cy="20" r="6" fill="#A78BFA"/>
        </svg>
        <span class="font-heading text-xl font-semibold text-[var(--color-text)] hidden sm:block">Espace Bienestar</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-medium transition-all duration-200 relative py-2",
              isActive(item.href) ? "text-[#7C5CBF]" : "text-[var(--color-text)] hover:text-[#7C5CBF]"
            ]}
          >
            {t.nav[item.key as keyof typeof t.nav]}
            {isActive(item.href) && (
              <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-[#A78BFA]"></span>
            )}
          </a>
        ))}
      </div>

      <a
        href={lang === 'fr' ? `${base}es` : base}
        class="bg-[#A78BFA] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#7C5CBF] transition-colors duration-200"
      >
        {lang === 'fr' ? 'ES' : 'FR'}
      </a>

      <button class="md:hidden text-[var(--color-text)] p-2" id="mobile-menu-toggle" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <div class="md:hidden hidden pb-6 space-y-1" id="mobile-menu">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            "block py-3 text-sm font-medium transition-colors",
            isActive(item.href) ? "text-[#7C5CBF]" : "text-[var(--color-text)] hover:text-[#7C5CBF]"
          ]}
        >
          {t.nav[item.key as keyof typeof t.nav]}
        </a>
      ))}
    </div>
  </div>

  <script>
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  </script>
</nav>