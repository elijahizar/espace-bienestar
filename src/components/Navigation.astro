---
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const navItems = [
  { key: 'home', href: lang === 'fr' ? `${base}` : `${base}es` },
  { key: 'activities', href: lang === 'fr' ? `${base}activities` : `${base}es/activities` },
  { key: 'about', href: lang === 'fr' ? `${base}about` : `${base}es/about` },
  { key: 'schedule', href: lang === 'fr' ? `${base}schedule` : `${base}es/schedule` },
  { key: 'contact', href: lang === 'fr' ? `${base}contact` : `${base}es/contact` },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => currentPath === href || currentPath === href + '/';
---

<nav class="bg-[var(--color-primary)] sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <a href={lang === 'fr' ? base : `${base}es`} class="flex items-center gap-3 group cursor-pointer">
        <svg class="w-10 h-10 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 40 40" fill="none">
          <circle cx="20" cy="20" r="18" stroke="white" stroke-width="2"/>
          <path d="M20 8C20 8 12 16 12 22C12 28 20 32 20 32C20 32 28 28 28 22C28 16 20 8 20 8Z" fill="white" opacity="0.3"/>
          <circle cx="20" cy="20" r="6" fill="var(--color-accent)"/>
        </svg>
        <span class="font-heading text-xl font-semibold text-[var(--color-text)] hidden sm:block">Espace Bienestar</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              "nav-link text-sm font-medium transition-all duration-200 relative py-2",
              isActive(item.href) ? "text-[var(--color-accent-dark)]" : "text-[var(--color-text)]"
            ]}
          >
            {t.nav[item.key as keyof typeof t.nav]}
            <span class="nav-link-underline"></span>
          </a>
        ))}
      </div>

      <a
        href={lang === 'fr' ? `${base}es` : base}
        class="bg-[var(--color-accent)] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[var(--color-accent-dark)] transition-colors duration-200"
      >
        {lang === 'fr' ? 'ES' : 'FR'}
      </a>

      <button class="md:hidden text-[var(--color-text)] p-2" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="w-6 h-6 menu-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg class="w-6 h-6 menu-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="md:hidden hidden pb-6 space-y-1" id="mobile-menu">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            "block py-3 text-sm font-medium transition-colors",
            isActive(item.href) ? "text-[var(--color-accent-dark)]" : "text-[var(--color-text)] hover:text-[var(--color-accent-dark)]"
          ]}
        >
          {t.nav[item.key as keyof typeof t.nav]}
        </a>
      ))}
    </div>
  </div>

  <script>
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!isOpen));
        toggle.querySelector('.menu-open')?.classList.toggle('hidden', !isOpen);
        toggle.querySelector('.menu-close')?.classList.toggle('hidden', isOpen);
      });
    }
  </script>

  <style>
    .nav-link {
      cursor: pointer;
    }

    .nav-link-underline {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--color-accent);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 0.3s ease;
    }

    .nav-link:hover .nav-link-underline,
    .nav-link:focus-visible .nav-link-underline {
      transform: scaleX(1);
    }

    .nav-link:hover,
    .nav-link:focus-visible {
      color: var(--color-accent-dark);
    }
  </style>
</nav>